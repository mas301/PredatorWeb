@namespace PredatorWeb.Components.Dialogs
@using PredatorWeb.Models
@using PredatorWeb.Services

<div class="modal-overlay" @onclick="OnCancel">
    <div class="modal-dialog" @onclick:stopPropagation="true">
        <div class="modal-header">
            <h3>Filtrar: @FormatColumnName(ColumnName ?? "")</h3>
        </div>
        <div class="modal-body">
            @if (ColumnType == ColumnFilterType.String)
            {
                <div class="filter-section">
                    <h4>Filtro de texto</h4>

                    @if (IsLoadingValues)
                    {
                        <div class="loading-values">Cargando valores...</div>
                    }
                    else if (AvailableValues != null && AvailableValues.Any())
                    {
                        <div class="filter-checkboxes">
                            <div class="checkbox-actions">
                                <button type="button" class="btn-link" @onclick="SelectAllValues">Seleccionar todos</button>
                                <button type="button" class="btn-link" @onclick="ClearAllValues">Limpiar todos</button>
                            </div>
                            <div class="checkbox-list">
                                @foreach (var value in AvailableValues)
                                {
                                    <label class="checkbox-item">
                                        <input type="checkbox" 
                                               checked="@localSelectedValues.Contains(value)"
                                               @onchange="@(e => ToggleValue(value, (bool)e.Value!))" />
                                        <span>@value</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="string-filter-section">
                            <select class="string-filter-select" @bind="localStringFilterType">
                                <option value="@StringFilterType.Contains">Contenga</option>
                                <option value="@StringFilterType.StartsWith">Empiece con</option>
                                <option value="@StringFilterType.EndsWith">Finalice con</option>
                                <option value="@StringFilterType.Equals">Que sea igual a</option>
                            </select>
                            <input type="text" 
                                   class="filter-input" 
                                   placeholder="Ingrese texto para filtrar..." 
                                   @bind="localFilterValue" />
                        </div>
                    }
                </div>
            }

            @if (ColumnType == ColumnFilterType.Date)
            {
                <div class="filter-section">
                    <h4>Filtro de fecha</h4>
                    <select class="date-filter-select" @bind="localDateFilterType" @bind:after="OnDateFilterTypeChanged">
                        <option value="@DateFilterType.Today">Hoy</option>
                        <option value="@DateFilterType.Yesterday">Ayer</option>
                        <option value="@DateFilterType.ThisWeek">Esta Semana</option>
                        <option value="@DateFilterType.LastWeek">Semana Anterior</option>
                        <option value="@DateFilterType.ThisMonth">Este Mes</option>
                        <option value="@DateFilterType.LastMonth">Mes Anterior</option>
                        <option value="@DateFilterType.ThisYear">Este Año</option>
                        <option value="@DateFilterType.LastYear">Año Anterior</option>
                        <option value="@DateFilterType.CustomRange">Rango de fechas</option>
                    </select>

                    <div class="date-range-inputs">
                        <div class="date-input-group">
                            <label>Desde:</label>
                            <input type="date" class="date-input" @bind="localDateFrom" />
                        </div>
                        <div class="date-input-group">
                            <label>Hasta:</label>
                            <input type="date" class="date-input" @bind="localDateTo" />
                        </div>
                    </div>
                </div>
            }

            @if (ColumnType == ColumnFilterType.Boolean)
            {
                <div class="filter-section">
                    <h4>Filtro de checkbox</h4>
                    <div class="filter-checkboxes">
                        <div class="checkbox-actions">
                            <button type="button" class="btn-link" @onclick="SelectAllBooleanValues">Seleccionar todos</button>
                            <button type="button" class="btn-link" @onclick="ClearAllBooleanValues">Limpiar todos</button>
                        </div>
                        <div class="checkbox-list">
                            <label class="checkbox-item">
                                <input type="checkbox" 
                                       checked="@localBooleanYes"
                                       @onchange="@(e => localBooleanYes = (bool)e.Value!)" />
                                <span>Sí</span>
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox" 
                                       checked="@localBooleanNo"
                                       @onchange="@(e => localBooleanNo = (bool)e.Value!)" />
                                <span>No</span>
                            </label>
                        </div>
                    </div>
                </div>
            }

            @if (ColumnType == ColumnFilterType.Numeric)
            {
                <div class="filter-section">
                    <h4>Filtro numérico</h4>
                    <select class="numeric-filter-select" @bind="localNumericFilterType">
                        <option value="@NumericFilterType.Equal">Igual a (=)</option>
                        <option value="@NumericFilterType.NotEqual">Diferente de (≠)</option>
                        <option value="@NumericFilterType.GreaterThan">Mayor que (&gt;)</option>
                        <option value="@NumericFilterType.GreaterThanOrEqual">Mayor o igual (≥)</option>
                        <option value="@NumericFilterType.LessThan">Menor que (&lt;)</option>
                        <option value="@NumericFilterType.LessThanOrEqual">Menor o igual (≤)</option>
                        <option value="@NumericFilterType.Between">Entre (rango)</option>
                    </select>

                    <div class="numeric-inputs">
                        <div class="numeric-input-group">
                            <label>@GetNumericLabel1():</label>
                            <input type="number" 
                                   step="any" 
                                   class="numeric-input" 
                                   @bind="localNumericValue1" 
                                   placeholder="Ingrese valor..." />
                        </div>

                        <div class="numeric-input-group" style="@(localNumericFilterType == NumericFilterType.Between ? "" : "display: none;")">
                            <label>Hasta:</label>
                            <input type="number" 
                                   step="any" 
                                   class="numeric-input" 
                                   @bind="localNumericValue2" 
                                   placeholder="Ingrese valor..." 
                                   disabled="@(localNumericFilterType != NumericFilterType.Between)" />
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="modal-footer">
            <button class="btn-modal btn-clear" @onclick="HandleClear" disabled="@(!HasActiveFilters())">Limpiar</button>
            <button class="btn-modal btn-cancel" @onclick="OnCancel">Cancelar</button>
            <button class="btn-modal btn-accept" @onclick="HandleAccept">Aceptar</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? ColumnName { get; set; }
    [Parameter] public ColumnFilterType ColumnType { get; set; }
    [Parameter] public bool SortAscending { get; set; } = true;
    [Parameter] public string FilterValue { get; set; } = "";
    [Parameter] public StringFilterType StringFilterType { get; set; } = StringFilterType.Contains;
    [Parameter] public List<string>? AvailableValues { get; set; }
    [Parameter] public HashSet<string> SelectedValues { get; set; } = new();
    [Parameter] public bool IsLoadingValues { get; set; }
    [Parameter] public DateFilterType DateFilterType { get; set; } = DateFilterType.None;
    [Parameter] public DateTime? DateFrom { get; set; }
    [Parameter] public DateTime? DateTo { get; set; }
    [Parameter] public BooleanFilterType BooleanFilterType { get; set; } = BooleanFilterType.All;
    [Parameter] public NumericFilterType NumericFilterType { get; set; } = NumericFilterType.None;
    [Parameter] public decimal? NumericValue1 { get; set; }
    [Parameter] public decimal? NumericValue2 { get; set; }

    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback<SortFilterResult> OnAccept { get; set; }

    private string localFilterValue = "";
    private StringFilterType localStringFilterType = StringFilterType.Contains;
    private HashSet<string> localSelectedValues = new();
    private DateFilterType localDateFilterType = DateFilterType.Today;
    private DateTime? localDateFrom;
    private DateTime? localDateTo;
    private BooleanFilterType localBooleanFilterType = BooleanFilterType.All;
    private bool localBooleanYes = false;
    private bool localBooleanNo = false;
    private NumericFilterType localNumericFilterType = NumericFilterType.Equal;
    private decimal? localNumericValue1;
    private decimal? localNumericValue2;

    protected override void OnParametersSet()
    {
        localFilterValue = FilterValue;
        localStringFilterType = StringFilterType;
        localSelectedValues = new HashSet<string>(SelectedValues);
        localDateFilterType = DateFilterType;
        localDateFrom = DateFrom;
        localDateTo = DateTo;
        localBooleanFilterType = BooleanFilterType;

        // Convertir BooleanFilterType a checkboxes
        localBooleanYes = BooleanFilterType == BooleanFilterType.All || BooleanFilterType == BooleanFilterType.Checked;
        localBooleanNo = BooleanFilterType == BooleanFilterType.All || BooleanFilterType == BooleanFilterType.Unchecked;

        // Inicializar el filtro numérico
        localNumericFilterType = NumericFilterType;
        localNumericValue1 = NumericValue1;
        localNumericValue2 = NumericValue2;
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
    }

    private string FormatColumnName(string columnName)
    {
        if (string.IsNullOrWhiteSpace(columnName))
            return columnName;

        var formatted = System.Text.RegularExpressions.Regex.Replace(columnName, "([a-z])([A-Z])", "$1 $2");
        return char.ToUpper(formatted[0]) + formatted.Substring(1);
    }

    private void ToggleValue(string value, bool isChecked)
    {
        if (isChecked)
            localSelectedValues.Add(value);
        else
            localSelectedValues.Remove(value);
    }

    private void SelectAllValues()
    {
        if (AvailableValues != null)
            localSelectedValues = new HashSet<string>(AvailableValues);
    }

    private void ClearAllValues()
    {
        localSelectedValues.Clear();
    }

    private void SelectAllBooleanValues()
    {
        localBooleanYes = true;
        localBooleanNo = true;
    }

    private void ClearAllBooleanValues()
    {
        localBooleanYes = false;
        localBooleanNo = false;
    }

    private bool HasActiveFilters()
    {
        // Verificar filtro de texto legacy
        if (!string.IsNullOrWhiteSpace(localFilterValue))
            return true;

        // Verificar filtro multi-valor
        if (localSelectedValues.Any())
            return true;

        // Verificar filtro de fecha
        if (localDateFilterType != DateFilterType.None)
            return true;

        // Verificar filtro booleano
        if (localBooleanFilterType != BooleanFilterType.All)
            return true;

        // Verificar filtro numérico
        if (localNumericFilterType != NumericFilterType.None)
            return true;

        return false;
    }

    private string GetNumericLabel1()
    {
        return localNumericFilterType switch
        {
            NumericFilterType.Between => "Desde",
            _ => "Valor"
        };
    }

    private async Task OnDateFilterTypeChanged()
    {
        var today = DateTime.Today;

        switch (localDateFilterType)
        {
            case Models.DateFilterType.None:
                // Sin filtro - no cambiar las fechas
                break;

            case Models.DateFilterType.Today:
                // Hoy - desde y hasta hoy
                localDateFrom = today;
                localDateTo = today;
                break;

            case Models.DateFilterType.Yesterday:
                // Ayer - desde y hasta ayer
                var yesterday = today.AddDays(-1);
                localDateFrom = yesterday;
                localDateTo = yesterday;
                break;

            case Models.DateFilterType.ThisWeek:
                // Esta semana - desde el lunes hasta el domingo
                var dayOfWeek = (int)today.DayOfWeek;
                var daysFromMonday = dayOfWeek == 0 ? 6 : dayOfWeek - 1; // Domingo = 0, ajustar para que lunes sea el primer día
                localDateFrom = today.AddDays(-daysFromMonday);
                localDateTo = localDateFrom.Value.AddDays(6);
                break;

            case Models.DateFilterType.LastWeek:
                // Semana anterior - desde el lunes hasta el domingo de la semana pasada
                var lastWeekDayOfWeek = (int)today.DayOfWeek;
                var lastWeekDaysFromMonday = lastWeekDayOfWeek == 0 ? 6 : lastWeekDayOfWeek - 1;
                var lastWeekMonday = today.AddDays(-lastWeekDaysFromMonday - 7);
                localDateFrom = lastWeekMonday;
                localDateTo = lastWeekMonday.AddDays(6);
                break;

            case Models.DateFilterType.ThisMonth:
                // Este mes - desde el día 1 hasta el último día del mes
                localDateFrom = new DateTime(today.Year, today.Month, 1);
                localDateTo = localDateFrom.Value.AddMonths(1).AddDays(-1);
                break;

            case Models.DateFilterType.LastMonth:
                // Mes anterior - desde el día 1 hasta el último día del mes pasado
                var lastMonth = today.AddMonths(-1);
                localDateFrom = new DateTime(lastMonth.Year, lastMonth.Month, 1);
                localDateTo = localDateFrom.Value.AddMonths(1).AddDays(-1);
                break;

            case Models.DateFilterType.ThisYear:
                // Este año - desde el 1 de enero hasta el 31 de diciembre
                localDateFrom = new DateTime(today.Year, 1, 1);
                localDateTo = new DateTime(today.Year, 12, 31);
                break;

            case Models.DateFilterType.LastYear:
                // Año anterior - desde el 1 de enero hasta el 31 de diciembre del año pasado
                var lastYear = today.Year - 1;
                localDateFrom = new DateTime(lastYear, 1, 1);
                localDateTo = new DateTime(lastYear, 12, 31);
                break;

            case Models.DateFilterType.CustomRange:
                // Rango personalizado - no cambiar las fechas, permitir entrada manual
                // Si están vacías, inicializar con hoy
                if (!localDateFrom.HasValue)
                    localDateFrom = today;
                if (!localDateTo.HasValue)
                    localDateTo = today;
                break;
        }

        await Task.CompletedTask;
    }

    private async Task HandleClear()
    {
        // Limpiar todos los valores de filtros
        localFilterValue = "";
        localStringFilterType = StringFilterType.Contains;
        localSelectedValues.Clear();
        localDateFilterType = DateFilterType.None;
        localDateFrom = null;
        localDateTo = null;
        localBooleanFilterType = BooleanFilterType.All;
        localBooleanYes = false;
        localBooleanNo = false;
        localNumericFilterType = NumericFilterType.None;
        localNumericValue1 = null;
        localNumericValue2 = null;

        // Aplicar los cambios (enviar valores vacíos) y cerrar el diálogo
        var result = new SortFilterResult
        {
            SortAscending = SortAscending, // Mantener el ordenamiento actual sin cambios
            FilterValue = "",
            StringFilterType = StringFilterType.Contains,
            SelectedValues = new List<string>(),
            DateFilterType = DateFilterType.None,
            DateFrom = null,
            DateTo = null,
            BooleanFilterType = BooleanFilterType.All,
            NumericFilterType = NumericFilterType.None,
            NumericValue1 = null,
            NumericValue2 = null
        };

        await OnAccept.InvokeAsync(result);
    }

    private async Task HandleAccept()
    {
        // Convertir checkboxes booleanos a BooleanFilterType
        BooleanFilterType booleanResult;
        if (localBooleanYes && localBooleanNo)
            booleanResult = BooleanFilterType.All;
        else if (localBooleanYes && !localBooleanNo)
            booleanResult = BooleanFilterType.Checked;
        else if (!localBooleanYes && localBooleanNo)
            booleanResult = BooleanFilterType.Unchecked;
        else
            booleanResult = BooleanFilterType.All; // Si ambos están desmarcados, mostrar todos

        var result = new SortFilterResult
        {
            SortAscending = SortAscending, // Mantener el ordenamiento actual sin cambios
            FilterValue = localFilterValue,
            StringFilterType = localStringFilterType,
            SelectedValues = localSelectedValues.ToList(),
            DateFilterType = localDateFilterType,
            DateFrom = localDateFrom,
            DateTo = localDateTo,
            BooleanFilterType = booleanResult,
            NumericFilterType = localNumericFilterType,
            NumericValue1 = localNumericValue1,
            NumericValue2 = localNumericValue2
        };

        await OnAccept.InvokeAsync(result);
    }
}
