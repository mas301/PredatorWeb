@using DevExpress.Blazor
@using PredatorWeb.Models

<div class="grid-container">
    <DxGrid Data="@gridData"
            CssClass="grid-full-height"
            ShowFilterRow="true"
            ShowSearchBox="true"
            ColumnResizeMode="GridColumnResizeMode.NextColumn"
            PageSize="20">
        <Columns>
            <DxGridDataColumn FieldName="Id" Caption="ID" Width="80px" />
            <DxGridDataColumn FieldName="Nombre" Caption="Nombre" Width="200px" />
            <DxGridDataColumn FieldName="Descripcion" Caption="Descripción" Width="300px" />
            <DxGridDataColumn FieldName="Cantidad" Caption="Cantidad" Width="120px" />
            <DxGridDataColumn FieldName="Precio" Caption="Precio" Width="120px" DisplayFormat="C2" />
            <DxGridDataColumn FieldName="Fecha" Caption="Fecha" Width="150px" DisplayFormat="dd/MM/yyyy" />
            <DxGridDataColumn FieldName="Estado" Caption="Estado" Width="120px" />
        </Columns>
    </DxGrid>
</div>

@code {
    [Parameter]
    public string? NombreEntidad { get; set; }

    private List<GridDataItem> gridData = new();

    protected override void OnInitialized()
    {
        GenerateRandomData();
    }

    protected override void OnParametersSet()
    {
        // Regenerar datos cuando se activa la pestaña
        if (gridData.Count == 0)
        {
            GenerateRandomData();
        }
    }

    private void GenerateRandomData()
    {
        var random = new Random();
        var estados = new[] { "Activo", "Inactivo", "Pendiente", "Procesado" };
        var nombres = new[] { "Producto A", "Producto B", "Producto C", "Servicio X", "Servicio Y", "Artículo Z" };
        var descripciones = new[] 
        { 
            "Descripción detallada del item", 
            "Item de alta calidad", 
            "Producto premium", 
            "Servicio especializado",
            "Artículo estándar",
            "Elemento básico"
        };

        gridData.Clear();

        for (int i = 1; i <= 100; i++)
        {
            gridData.Add(new GridDataItem
            {
                Id = i,
                Nombre = $"{nombres[random.Next(nombres.Length)]} {i}",
                Descripcion = descripciones[random.Next(descripciones.Length)],
                Cantidad = random.Next(1, 1000),
                Precio = Math.Round((decimal)(random.NextDouble() * 10000), 2),
                Fecha = DateTime.Now.AddDays(-random.Next(0, 365)),
                Estado = estados[random.Next(estados.Length)]
            });
        }
    }

    public class GridDataItem
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = string.Empty;
        public string Descripcion { get; set; } = string.Empty;
        public int Cantidad { get; set; }
        public decimal Precio { get; set; }
        public DateTime Fecha { get; set; }
        public string Estado { get; set; } = string.Empty;
    }
}
