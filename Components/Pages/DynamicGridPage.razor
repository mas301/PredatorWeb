    private async Task OnExportar()
    {
        if (state.GridData == null || state.GridData.Rows.Count == 0)
            return;

        // Mostrar indicador de carga inmediatamente
        state.IsLoading = true;
        state.ShowLoadingDialog = true;
        state.LoadingMessage = "Generando archivo Excel...";
        StateHasChanged();

        try
        {
            // Preparar el DataTable en el hilo actual (acceso a UI state)
            var exportTable = new DataTable();

            foreach (DataColumn column in state.GridData.Columns)
            {
                if (!ShouldHideColumn(column.ColumnName))
                {
                    var displayName = GetColumnDisplayName(column.ColumnName);
                    exportTable.Columns.Add(displayName, column.DataType);
                }
            }

            foreach (DataRow row in GetFilteredData())
            {
                var newRow = exportTable.NewRow();
                int colIndex = 0;
                foreach (DataColumn column in state.GridData.Columns)
                {
                    if (!ShouldHideColumn(column.ColumnName))
                    {
                        newRow[colIndex++] = row[column.ColumnName];
                    }
                }
                exportTable.Rows.Add(newRow);
            }

            var sheetName = (NombreEntidad ?? "Datos");
            if (sheetName.Length > 31)
                sheetName = sheetName[..31];

            var fileName = $"{NombreEntidad}_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";

            // Generar el Excel en un hilo de fondo para no bloquear la UI
            var excelBytes = await Task.Run(() => ExcelExportService.ExportToExcel(exportTable, sheetName));

            // Descargar el archivo usando JavaScript
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(excelBytes));
        }
        catch (Exception ex)
        {
            state.ErrorMessage = $"Error al exportar: {ex.Message}";
            if (ex.InnerException != null)
                state.ErrorMessage += $"\n{ex.InnerException.Message}";
        }
        finally
        {
            state.IsLoading = false;
            state.ShowLoadingDialog = false;
            StateHasChanged();
        }
    }

    private async Task OnRefrescar()
    {
        // Verificar si hay filtros activos para respetarlos al refrescar
        bool hasActiveFilters = state.ColumnFilters.Any() ||
                               state.MultiValueFilters.Any() ||
                               state.DateFilters.Any() ||
                               state.BooleanFilters.Any();

        if (hasActiveFilters)
        {
            // Si hay filtros, recargar aplicándolos
            await ReloadDataWithFiltersAsync();
        }
        else
        {
            // Si no hay filtros, cargar normalmente
            await LoadDataAsync();
        }
    }

