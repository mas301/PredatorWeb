@using System.Data
@using PredatorWeb.Models
@using Microsoft.JSInterop
@inject Services.EntidadService EntidadService
@inject Services.ExcelExportService ExcelExportService
@inject Services.ConfigurationService ConfigurationService
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div class="grid-container">
    <!-- Diálogo de carga - SIEMPRE visible si está cargando -->
    @if (state.IsLoading && state.ShowLoadingDialog)
    {
        <div class="loading-overlay">
            <div class="loading-dialog">
                <h3>@state.LoadingMessage</h3>
                <div class="loading-spinner"></div>
                @if (state.ProgressPercentage > 0)
                {
                    <div class="progress-bar-container">
                        <div class="progress-bar" style="width: @(state.ProgressPercentage)%"></div>
                    </div>
                    <p class="progress-text">@state.ProgressPercentage%</p>
                }
                <button class="btn-cancel-loading" @onclick="CancelLoading">
                    ✖ Cancelar
                </button>
            </div>
        </div>
    }

    @if (state.ErrorMessage != null)
    {
        <div class="error-message">
            <h3>Error al cargar datos:</h3>
            <p>@state.ErrorMessage</p>
            @if (state.StackTrace != null)
            {
                <details>
                    <summary>Detalles del error</summary>
                    <pre>@state.StackTrace</pre>
                </details>
            }
        </div>
    }
    else if (state.GridData != null)
    {
        <!-- Barra de herramientas -->
        <div class="toolbar">
            <button class="toolbar-btn" @onclick="OnIngresar" title="Ingresar">
                <span class="btn-icon">➕</span>
                <span class="btn-text">Ingresar</span>
            </button>
            <button class="toolbar-btn" @onclick="OnModificar" disabled="@(!CanModify())" title="Modificar">
                <span class="btn-icon">✏️</span>
                <span class="btn-text">Modificar</span>
            </button>
            <button class="toolbar-btn" @onclick="OnConsultar" disabled="@(!CanConsult())" title="Consultar">
                <span class="btn-icon">👁️</span>
                <span class="btn-text">Consultar</span>
            </button>
            <div class="toolbar-separator"></div>
            <button class="toolbar-btn" @onclick="OnDesactivar" disabled="@(!CanDeactivate())" title="Desactivar">
                <span class="btn-icon">🚫</span>
                <span class="btn-text">Desactivar</span>
            </button>
            <button class="toolbar-btn" @onclick="OnReactivar" disabled="@(!CanReactivate())" title="Reactivar">
                <span class="btn-icon">✅</span>
                <span class="btn-text">Reactivar</span>
            </button>
            <button class="toolbar-btn toolbar-btn-danger" @onclick="OnEliminar" disabled="@(!CanDelete())" title="Eliminar">
                <span class="btn-icon">🗑️</span>
                <span class="btn-text">Eliminar</span>
            </button>
            <div class="toolbar-separator"></div>
            <button class="toolbar-btn" @onclick="OnImprimir" title="Imprimir">
                <span class="btn-icon">🖨️</span>
                <span class="btn-text">Imprimir</span>
            </button>
            <button class="toolbar-btn" @onclick="OnImportar" title="Importar">
                <span class="btn-icon">📥</span>
                <span class="btn-text">Importar</span>
            </button>
            <button class="toolbar-btn" @onclick="OnExportar" title="Exportar">
                <span class="btn-icon">📤</span>
                <span class="btn-text">Exportar</span>
            </button>
            <div class="toolbar-separator"></div>
            <button class="toolbar-btn" @onclick="OnRefrescar" title="Refrescar">
                <span class="btn-icon">🔄</span>
                <span class="btn-text">Refrescar</span>
            </button>
            <button class="toolbar-btn" @onclick="OnColumnas" title="Columnas">
                <span class="btn-icon">📋</span>
                <span class="btn-text">Columnas</span>
            </button>
            <button class="toolbar-btn" @onclick="OnPropiedades" title="Propiedades">
                <span class="btn-icon">⚙️</span>
                <span class="btn-text">Propied</span>
            </button>

            @if (state.ShowPagination)
            {
                <div class="toolbar-separator"></div>
                <button class="toolbar-btn toolbar-btn-nav" 
                        @onclick="FirstPage" 
                        disabled="@(state.CurrentPage == 1)"
                        title="Primera página">
                    <span class="btn-icon">⏮</span>
                    <span class="btn-text">Primera</span>
                </button>
                <button class="toolbar-btn toolbar-btn-nav" 
                        @onclick="PreviousPage" 
                        disabled="@(state.CurrentPage == 1)"
                        title="Página anterior">
                    <span class="btn-icon">◀</span>
                    <span class="btn-text">Anterior</span>
                </button>
                <button class="toolbar-btn toolbar-btn-nav" 
                        @onclick="NextPage" 
                        disabled="@(state.CurrentPage >= state.TotalPages)"
                        title="Página siguiente">
                    <span class="btn-icon">▶</span>
                    <span class="btn-text">Siguiente</span>
                </button>
                <button class="toolbar-btn toolbar-btn-nav" 
                        @onclick="LastPage" 
                        disabled="@(state.CurrentPage >= state.TotalPages)"
                        title="Última página">
                    <span class="btn-icon">⏭</span>
                    <span class="btn-text">Última</span>
                </button>
            }
        </div>

        <!-- Barra de filtros -->
        @if (HasActiveFilters())
        {
            <div class="filter-bar">
                <button class="btn-clear-all-filters" @onclick="ClearAllFilters">
                    🗑️ Limpiar Filtro
                </button>
                <div class="filter-display">
                    <span class="filter-label">Filtros activos:</span>
                    <span class="filter-text">@GetFilterDescription()</span>
                </div>
            </div>
        }

        <div class="table-wrapper">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th class="checkbox-column">
                            <div class="th-container">
                                <input type="checkbox"
                                       checked="@AreAllSelected()"
                                       @onchange="ToggleSelectAll" />
                                <div class="th-icons">
                                    <span class="th-icon sort-icon @(state.SortColumn == "_Selection" ? "active" : "")"
                                          @onclick="@(() => OnSortSelection())"
                                          @onclick:stopPropagation="true"
                                          title="Ordenar">
                                        @if (state.SortColumn == "_Selection")
                                        {
                                            @(state.SortAscending ? "▲" : "▼")
                                        }
                                        else
                                        {
                                            <text>⇅</text>
                                        }
                                    </span>
                                </div>
                            </div>
                         </th>
                        @foreach (DataColumn column in GetOrderedColumns())
                        {
                            @if (!ShouldHideColumn(column.ColumnName))
                            {
                                <th class="@(IsNumericColumn(column) ? "text-right" : "")">
                                    <div class="th-container">
                                        <span class="th-title">@GetColumnDisplayName(column.ColumnName)</span>
                                        <div class="th-icons">
                                            <span class="th-icon filter-icon @(HasActiveFilter(column.ColumnName) ? "active" : "")" 
                                                  @onclick="@(() => ShowFilterDialog(column.ColumnName))"
                                                  @onclick:stopPropagation="true"
                                                  title="Filtrar">
                                                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2z"/>
                                                </svg>
                                            </span>
                                            <span class="th-icon sort-icon @(state.SortColumn == column.ColumnName ? "active" : "")" 
                                                  @onclick="@(() => ToggleSort(column.ColumnName))"
                                                  @onclick:stopPropagation="true"
                                                  title="Ordenar">
                                                @if (state.SortColumn == column.ColumnName)
                                                {
                                                    @(state.SortAscending ? "▲" : "▼")
                                                }
                                                else
                                                {
                                                    <text>⇅</text>
                                                }
                                            </span>
                                        </div>
                                    </div>
                                </th>
                            }
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (state.GridData.Rows.Count > 0)
                    {
                        @foreach (DataRow row in GetPagedData())
                        {
                            var currentRow = row; // Variable local para captura correcta en lambdas
                            var rowId = GetRowId(currentRow); // Obtener ID para el @key directive
                            <tr @key="rowId" 
                                class="@(IsRowSelected(currentRow) ? "row-selected" : "")" 
                                @onclick="@(() => SelectSingleRow(currentRow))" 
                                style="cursor: pointer;">
                                <td class="checkbox-column" @onclick:stopPropagation="true">
                                    <input type="checkbox"
                                                       checked="@IsRowSelected(currentRow)"
                                                       @onchange="@(e => ToggleRowSelection(currentRow, e))" />
                                            </td>
                                           @foreach (DataColumn column in GetOrderedColumns())
                                           {
                                               @if (!ShouldHideColumn(column.ColumnName))
                                    {
                                        <td class="@(IsNumericColumn(column) ? "text-right" : "")">
                                            @if (IsBooleanColumn(column))
                                            {
                                                <input type="checkbox" 
                                                       checked="@GetBooleanValue(currentRow[column])" 
                                                       disabled 
                                                       style="cursor: default;" />
                                            }
                                            else
                                            {
                                                @FormatCellValue(currentRow[column], column)
                                            }
                                        </td>
                                    }
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="@(GetOrderedColumns().Where(c => !ShouldHideColumn(c.ColumnName)).Count() + 1)" style="text-align: center; padding: 40px; color: #666;">
                                <strong>No se encontraron registros que cumplan con los criterios de búsqueda.</strong>
                                @if (HasActiveFilters())
                                {
                                    <br/><br/>
                                    <span>Intenta modificar o eliminar los filtros activos.</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="totals-row">
                        <td class="totals-label" colspan="@GetTotalLabelColspan()">
                            <div class="totals-content">
                                <span class="totals-text-nowrap">
                                    Total de registros: @GetFilteredData().Count()@(state.ShowPagination ? $" (Página {state.CurrentPage} de {state.TotalPages})" : "")
                                </span>
                                @if (state.SelectedRowIds.Count > 0)
                                {
                                    <span class="totals-separator">|</span>
                                    <span class="totals-selected-count">
                                        ✓ Seleccionados: @state.SelectedRowIds.Count
                                    </span>
                                }
                                @if (state.ShowPagination)
                                {
                                    <span class="totals-separator">|</span>
                                    <span class="totals-page-size">
                                        <label>Reg. x Pág.:</label>
                                        <select @onchange="OnPageSizeChanged" value="@state.PageSize">
                                            <option value="50">50</option>
                                            <option value="100">100</option>
                                            <option value="250">250</option>
                                            <option value="500">500</option>
                                            <option value="1000">1000</option>
                                        </select>
                                    </span>
                                }
                            </div>
                        </td>
                        @{
                            var columnsToSkip = GetTotalLabelColspan() - 1; // -1 porque ya contamos el checkbox
                            var columnIndex = 0;
                        }
                        @foreach (DataColumn column in GetOrderedColumns())
                        {
                            @if (!ShouldHideColumn(column.ColumnName))
                            {
                                columnIndex++;
                                @if (columnIndex > columnsToSkip)
                                {
                                    <td class="@(IsNumericColumn(column) ? "text-right" : "")">
                                        @if (ShouldShowTotal(column.ColumnName))
                                        {
                                            @FormatTotal(GetColumnTotal(column))
                                        }
                                    </td>
                                }
                            }
                        }
                    </tr>
                </tfoot>
            </table>
        </div>

        <!-- Panel de pie eliminado, ahora el resumen está en tfoot -->
    }
    else
    {
        <div class="no-data-message">
            <p>No se encontraron datos para mostrar.</p>
            <p>Entidad: @NombreEntidad</p>
        </div>
    }

    <!-- Diálogo de ordenamiento y filtrado -->
    @if (state.ShowSortDialog)
    {
        <SortFilterDialog 
            ColumnName="@state.SelectedColumnForSort"
            ColumnType="@GetColumnFilterType()"
            SortAscending="@state.TempSortAscending"
            FilterValue="@state.TempFilterValue"
            StringFilterType="@state.TempStringFilterType"
            AvailableValues="@state.AvailableFilterValues"
            SelectedValues="@state.SelectedFilterValues"
            IsLoadingValues="@state.IsLoadingFilterValues"
            DateFilterType="@state.TempDateFilterType"
            DateFrom="@state.TempDateFrom"
            DateTo="@state.TempDateTo"
            BooleanFilterType="@state.TempBooleanFilterType"
            NumericFilterType="@state.TempNumericFilterType"
            NumericValue1="@state.TempNumericValue1"
            NumericValue2="@state.TempNumericValue2"
            OnCancel="@CancelSort"
            OnAccept="@HandleSortFilterAccept" />
    }

    <!-- Diálogo de configuración de columnas -->
    @if (state.ShowColumnDialog)
    {
        <ColumnConfigDialog 
            ColumnConfigs="@state.ColumnConfigs"
            OnCancel="@CancelColumnConfig"
            OnAccept="@HandleColumnConfigAccept" />
    }

    <!-- Diálogo de vista previa de impresión -->
    @if (state.ShowPrintPreview && state.PrintPreviewData != null)
    {
        <PrintPreviewDialog 
            Title="@NombreEntidad"
            PreviewData="@state.PrintPreviewData"
            OnClose="@ClosePrintPreview"
            OnExport="@ExportFromPreview"
            OnPrint="@PrintFromPreview" />
    }
</div>

@code {
    [Parameter]
    public string? NombreEntidad { get; set; }

    [Parameter]
    public EventCallback<(string Title, DataTable Data)> OpenPrintPreviewTab { get; set; }

    // Estado encapsulado de la grilla
    private GridPageState state = new();

    // Helpers para trabajar con selección basada en IDs
    private string? GetRowId(DataRow row)
    {
        var entidad = EntidadService.GetEntidad(NombreEntidad);
        if (entidad == null || string.IsNullOrEmpty(entidad.NombreClavePrimaria))
        {
            return null;
        }

        if (!row.Table.Columns.Contains(entidad.NombreClavePrimaria))
        {
            return null;
        }

        return row[entidad.NombreClavePrimaria]?.ToString();
    }

    private bool IsRowSelected(DataRow row)
    {
        var id = GetRowId(row);
        return id != null && state.SelectedRowIds.Contains(id);
    }

    private DataRow? GetSelectedRow()
    {
        if (state.SelectedRowIds.Count != 1 || state.GridData == null)
            return null;

        var id = state.SelectedRowIds.First();
        var entidad = EntidadService.GetEntidad(NombreEntidad);
        if (entidad == null || string.IsNullOrEmpty(entidad.NombreClavePrimaria))
            return null;

        return state.GridData.AsEnumerable()
            .FirstOrDefault(row => row[entidad.NombreClavePrimaria]?.ToString() == id);
    }

    private List<DataRow> GetSelectedRows()
    {
        if (state.SelectedRowIds.Count == 0 || state.GridData == null)
            return new List<DataRow>();

        var entidad = EntidadService.GetEntidad(NombreEntidad);
        if (entidad == null || string.IsNullOrEmpty(entidad.NombreClavePrimaria))
            return new List<DataRow>();

        return state.GridData.AsEnumerable()
            .Where(row =>
            {
                var id = row[entidad.NombreClavePrimaria]?.ToString();
                return id != null && state.SelectedRowIds.Contains(id);
            })
            .ToList();
    }

    // Limpia los IDs seleccionados que ya no existen en los datos actuales
    private void CleanupOrphanedSelections()
    {
        if (state.GridData == null || state.SelectedRowIds.Count == 0)
            return;

        var entidad = EntidadService.GetEntidad(NombreEntidad);
        if (entidad == null || string.IsNullOrEmpty(entidad.NombreClavePrimaria))
            return;

        // Obtener todos los IDs que existen en los datos actuales
        var existingIds = state.GridData.AsEnumerable()
            .Select(row => row[entidad.NombreClavePrimaria]?.ToString())
            .Where(id => id != null)
            .ToHashSet();

        // Remover IDs que ya no existen
        var orphanedIds = state.SelectedRowIds
            .Where(id => !existingIds.Contains(id))
            .ToList();

        foreach (var orphanedId in orphanedIds)
        {
            state.SelectedRowIds.Remove(orphanedId);
        }
    }

    // Backup temporal de la configuración de columnas para "Cancelar"
    private List<ColumnConfig>? tempColumnConfigsBackup = null;

    public async ValueTask DisposeAsync()
    {
        // Guardar configuración antes de disponer
        await SaveGridConfigurationAsync();

        state.Dispose();
    }

    private bool _hasLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        // No hacer nada aquí, todo se maneja en OnParametersSetAsync
    }

    // Variable temporal para almacenar la configuración antes de aplicarla
    private Models.GridConfiguration? _pendingConfiguration = null;

    protected override async Task OnParametersSetAsync()
    {
        // Cargar solo si el NombreEntidad cambió o es la primera vez
        if (!_hasLoaded || _lastLoadedEntity != NombreEntidad)
        {
            _hasLoaded = true;
            _lastLoadedEntity = NombreEntidad;

            // PRIMERO: Cargar configuración guardada
            await LoadGridConfigurationAsync();

            // SEGUNDO: Verificar si hay filtros activos después de cargar la configuración
            bool hasActiveFilters = state.ColumnFilters.Any() || 
                                   state.MultiValueFilters.Any() || 
                                   state.DateFilters.Any() || 
                                   state.BooleanFilters.Any() ||
                                   state.StringFilters.Any() ||
                                   state.NumericFilters.Any(f => f.Value.Type != NumericFilterType.None);

            // TERCERO: Cargar datos con o sin filtros
            if (hasActiveFilters)
            {
                await ReloadDataWithFiltersAsync();
            }
            else
            {
                await LoadDataAsync();
            }
        }
    }

    private string? _lastLoadedEntity = null;

    private async Task LoadDataAsync()
    {
        if (string.IsNullOrEmpty(NombreEntidad))
            return;

        // Cancelar cualquier carga anterior en progreso
        state.CancellationTokenSource?.Cancel();
        state.CancellationTokenSource?.Dispose();
        state.CancellationTokenSource = new CancellationTokenSource();

        state.IsLoading = true;
        state.ShowLoadingDialog = true;
        state.ErrorMessage = null;
        state.StackTrace = null;
        state.ProgressPercentage = 10;
        state.LoadingMessage = "Cargando datos...";
        StateHasChanged();

        await Task.Delay(100);

        try
        {
            var token = state.CancellationTokenSource.Token;

            // Iniciar simulación de progreso en paralelo
            var progressTask = SimulateProgress(token);

            // Ejecutar en Task.Run() para no bloquear el circuito de Blazor
            var loadTask = Task.Run(async () =>
            {
                return await EntidadService.GetEntidadDataAsync(NombreEntidad, token);
            }, token);

            state.GridData = await loadTask;
            state.SelectedRowIds.Clear();

            // Inicializar configuración de columnas si no existe
            if (state.GridData != null && state.ColumnConfigs.Count == 0)
            {
                InitializeColumnConfigs();
                ApplyPendingConfiguration();
            }
        }
        catch (OperationCanceledException)
        {
            // No mostrar error cuando el usuario cancela
            state.ErrorMessage = null;
        }
        catch (Exception ex)
        {
            state.ErrorMessage = ex.Message;
            state.StackTrace = ex.StackTrace;
        }
        finally
        {
            // Forzar cierre del diálogo y actualizar UI
            state.IsLoading = false;
            state.ShowLoadingDialog = false;
            state.ProgressPercentage = 100;
            state.CancellationTokenSource?.Dispose();
            state.CancellationTokenSource = null;

            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SimulateProgress(CancellationToken token)
    {
        for (int i = 30; i < 85; i += 5)
        {
            if (token.IsCancellationRequested)
                return;

            state.ProgressPercentage = i;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(400, token);
        }
    }

    private async Task UpdateProgress(int percentage, string message, CancellationToken token)
    {
        token.ThrowIfCancellationRequested();
        state.ProgressPercentage = percentage;
        state.LoadingMessage = message;
        await InvokeAsync(StateHasChanged);
    }

    private void CancelLoading()
    {
        try
        {
            if (state.CancellationTokenSource != null)
            {
                try
                {
                    state.CancellationTokenSource.Cancel();
                }
                catch (ObjectDisposedException)
                {
                    // Token ya fue dispuesto
                }
                catch (AggregateException)
                {
                    // Excepciones agregadas durante la cancelación
                }
            }

            state.LoadingMessage = "Cancelando operación...";

            try
            {
                StateHasChanged();
            }
            catch
            {
                _ = InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error en CancelLoading: {ex.Message}");
        }
    }

    private IEnumerable<DataRow> GetPagedData()
    {
        var allData = GetFilteredData();

        // Aplicar paginación
        if (state.GridData != null && state.ShowPagination)
        {
            int skip = (state.CurrentPage - 1) * state.PageSize;
            return allData.Skip(skip).Take(state.PageSize);
        }

        return allData;
    }

    private IEnumerable<DataRow> GetFilteredData()
    {
        // Los datos ya vienen filtrados y ordenados desde el servidor
        // Excepto para el ordenamiento por selección que se hace en cliente
        if (state.GridData == null) return Enumerable.Empty<DataRow>();

        var data = state.GridData.AsEnumerable();

        // Aplicar ordenamiento por selección si corresponde
        if (state.SortColumn == "_Selection")
        {
            if (state.SortAscending)
            {
                // No seleccionados primero
                data = data.OrderBy(row => IsRowSelected(row));
            }
            else
            {
                // Seleccionados primero
                data = data.OrderByDescending(row => IsRowSelected(row));
            }
        }

        return data;
    }

    private async Task SortByColumn(string columnName)
    {
        if (state.SortColumn == columnName)
        {
            state.SortAscending = !state.SortAscending;
        }
        else
        {
            state.SortColumn = columnName;
            state.SortAscending = true;
        }

        // Recargar datos del servidor con el nuevo ordenamiento
        await ReloadDataWithFiltersAsync();
    }

    private async Task ShowSortDialog(string columnName)
    {
        state.SelectedColumnForSort = columnName;
        // Si la columna ya está ordenada, usar el mismo orden, sino ascendente por defecto
        if (state.SortColumn == columnName)
        {
            state.TempSortAscending = state.SortAscending;
        }
        else
        {
            state.TempSortAscending = true;
        }

        // Cargar el filtro de string con tipo existente para esta columna si existe
        if (state.StringFilters.ContainsKey(columnName))
        {
            var stringFilter = state.StringFilters[columnName];
            state.TempFilterValue = stringFilter.Value;
            state.TempStringFilterType = stringFilter.Type;
        }
        // Cargar el filtro de texto existente para esta columna si existe (compatibilidad con filtros antiguos)
        else if (state.ColumnFilters.ContainsKey(columnName))
        {
            state.TempFilterValue = state.ColumnFilters[columnName];
            state.TempStringFilterType = StringFilterType.Contains;
        }
        else
        {
            state.TempFilterValue = "";
            state.TempStringFilterType = StringFilterType.Contains;
        }

        // Cargar selecciones múltiples existentes
        if (state.MultiValueFilters.ContainsKey(columnName))
        {
            state.SelectedFilterValues = new HashSet<string>(state.MultiValueFilters[columnName]);
        }
        else
        {
            state.SelectedFilterValues.Clear();
        }

        // Cargar el filtro de fecha existente para esta columna si existe
        if (state.DateFilters.ContainsKey(columnName))
        {
            var dateFilter = state.DateFilters[columnName];
            state.TempDateFilterType = dateFilter.Type;
            state.TempDateFrom = dateFilter.From;
            state.TempDateTo = dateFilter.To;
        }
        else
        {
            state.TempDateFilterType = DateFilterType.None;
            state.TempDateFrom = null;
            state.TempDateTo = null;
        }

        // Cargar el filtro booleano existente para esta columna si existe
        if (state.BooleanFilters.ContainsKey(columnName))
        {
            state.TempBooleanFilterType = state.BooleanFilters[columnName];
        }
        else
        {
            state.TempBooleanFilterType = BooleanFilterType.All;
        }

        // Cargar el filtro numérico existente para esta columna si existe
        if (state.NumericFilters.ContainsKey(columnName))
        {
            var numericFilter = state.NumericFilters[columnName];
            state.TempNumericFilterType = numericFilter.Type;
            state.TempNumericValue1 = numericFilter.Value1;
            state.TempNumericValue2 = numericFilter.Value2;
        }
        else
        {
            state.TempNumericFilterType = NumericFilterType.None;
            state.TempNumericValue1 = null;
            state.TempNumericValue2 = null;
        }

        // Cargar valores únicos si es una columna de texto
        if (IsSelectedColumnString())
        {
            state.AvailableFilterValues = null;
            state.IsLoadingFilterValues = true;
            state.ShowSortDialog = true;
            StateHasChanged();

            try
            {
                var distinctValues = await EntidadService.GetDistinctValuesAsync(NombreEntidad, columnName);
                state.AvailableFilterValues = distinctValues;
            }
            catch (Exception ex)
            {
                // Si hay error, simplemente usar input de texto
                state.AvailableFilterValues = null;
            }
            finally
            {
                state.IsLoadingFilterValues = false;
                StateHasChanged();
            }
        }
        else
        {
            state.AvailableFilterValues = null;
            state.ShowSortDialog = true;
            StateHasChanged();
        }
    }

    private async Task AcceptSort()
    {
        if (!string.IsNullOrEmpty(state.SelectedColumnForSort))
        {
            // NOTA: Ya NO establecemos el ordenamiento automáticamente aquí
            // El ordenamiento solo se cambia desde el icono de ordenamiento (ToggleSort)
            // Este método ahora solo maneja filtros

            // Guardar o eliminar el filtro según el valor
            if (IsSelectedColumnString())
            {
                // Limpiar todos los tipos de filtros de esta columna primero
                state.ColumnFilters.Remove(state.SelectedColumnForSort);
                state.MultiValueFilters.Remove(state.SelectedColumnForSort);
                state.StringFilters.Remove(state.SelectedColumnForSort);

                // Si hay filtros por checkbox seleccionados
                if (state.SelectedFilterValues.Any())
                {
                    state.MultiValueFilters[state.SelectedColumnForSort] = state.SelectedFilterValues.ToList();
                }
                // Si hay texto en el filtro manual con tipo de coincidencia
                else if (!string.IsNullOrWhiteSpace(state.TempFilterValue))
                {
                    state.StringFilters[state.SelectedColumnForSort] = (state.TempStringFilterType, state.TempFilterValue);
                }
            }

            // Guardar o eliminar el filtro de fecha
            if (IsSelectedColumnDate())
            {
                if (state.TempDateFilterType != DateFilterType.None)
                {
                    state.DateFilters[state.SelectedColumnForSort] = (state.TempDateFilterType, state.TempDateFrom, state.TempDateTo);
                }
                else
                {
                    state.DateFilters.Remove(state.SelectedColumnForSort);
                }
            }

            // Guardar o eliminar el filtro booleano
            if (IsSelectedColumnBoolean())
            {
                if (state.TempBooleanFilterType != BooleanFilterType.All)
                {
                    state.BooleanFilters[state.SelectedColumnForSort] = state.TempBooleanFilterType;
                }
                else
                {
                    state.BooleanFilters.Remove(state.SelectedColumnForSort);
                }
            }

            // Guardar o eliminar el filtro numérico
            if (GetColumnFilterType() == ColumnFilterType.Numeric)
            {
                if (state.TempNumericFilterType != NumericFilterType.None)
                {
                    state.NumericFilters[state.SelectedColumnForSort] = (state.TempNumericFilterType, state.TempNumericValue1, state.TempNumericValue2);
                }
                else
                {
                    state.NumericFilters.Remove(state.SelectedColumnForSort);
                }
            }
        }
        state.ShowSortDialog = false;

        // Recargar datos desde el servidor con los filtros aplicados
        await ReloadDataWithFiltersAsync();
    }

    private async Task ShowFilterDialog(string columnName)
    {
        // Reutilizar la lógica de ShowSortDialog pero sin cambiar el orden
        await ShowSortDialog(columnName);
    }

    private async Task ToggleSort(string columnName)
    {
        // Si es la misma columna, invertir el orden
        if (state.SortColumn == columnName)
        {
            state.SortAscending = !state.SortAscending;
        }
        else
        {
            // Nueva columna, ordenar ascendente por defecto
            state.SortColumn = columnName;
            state.SortAscending = true;
        }

        // Ordenar en memoria usando DataView
        SortDataInMemory();

        // Forzar actualización de la UI
        StateHasChanged();

        await Task.CompletedTask;
    }

    private void SortDataInMemory()
    {
        if (state.GridData == null || string.IsNullOrEmpty(state.SortColumn))
            return;

        try
        {
            // Crear una vista del DataTable para ordenar
            var dataView = state.GridData.DefaultView;
            var direction = state.SortAscending ? "ASC" : "DESC";

            // Aplicar el ordenamiento
            dataView.Sort = $"{state.SortColumn} {direction}";

            // Crear un nuevo DataTable con los datos ordenados
            var sortedTable = dataView.ToTable();

            // Reemplazar el DataTable actual con el ordenado
            state.GridData = sortedTable;

            // Limpiar IDs seleccionados que ya no existen después de recrear la tabla
            CleanupOrphanedSelections();
        }
        catch (Exception ex)
        {
            // Si hay error al ordenar (ej: columna inválida), ignorar silenciosamente
            Console.WriteLine($"Error al ordenar en memoria: {ex.Message}");
        }
    }

    private async Task HandleSortFilterAccept(SortFilterResult result)
    {
        if (!string.IsNullOrEmpty(state.SelectedColumnForSort))
        {
            // NOTA: Ya NO establecemos el ordenamiento desde el diálogo de filtro
            // El ordenamiento solo se cambia desde el icono de ordenamiento directo

            // Actualizar los valores temporales desde el resultado
            state.TempFilterValue = result.FilterValue;
            state.TempStringFilterType = result.StringFilterType;
            state.SelectedFilterValues = new HashSet<string>(result.SelectedValues);
            state.TempDateFilterType = result.DateFilterType;
            state.TempDateFrom = result.DateFrom;
            state.TempDateTo = result.DateTo;
            state.TempBooleanFilterType = result.BooleanFilterType;
            state.TempNumericFilterType = result.NumericFilterType;
            state.TempNumericValue1 = result.NumericValue1;
            state.TempNumericValue2 = result.NumericValue2;

            // Procesar solo los filtros (sin cambiar el ordenamiento)
            await AcceptSort();
        }
    }

    private ColumnFilterType GetColumnFilterType()
    {
        if (IsSelectedColumnString())
            return ColumnFilterType.String;
        if (IsSelectedColumnDate())
            return ColumnFilterType.Date;
        if (IsSelectedColumnBoolean())
            return ColumnFilterType.Boolean;
        return ColumnFilterType.Numeric;
    }

    private async Task ReloadDataWithFiltersAsync()
    {
        if (string.IsNullOrEmpty(NombreEntidad))
            return;

        // Cancelar cualquier carga anterior en progreso
        state.CancellationTokenSource?.Cancel();
        state.CancellationTokenSource?.Dispose();
        state.CancellationTokenSource = new CancellationTokenSource();

        state.IsLoading = true;
        state.ShowLoadingDialog = true; // Mostrar INMEDIATAMENTE
        state.ErrorMessage = null;
        state.StackTrace = null;
        state.ProgressPercentage = 10;
        state.LoadingMessage = "Aplicando filtros...";
        StateHasChanged(); // Forzar actualización inmediata

        // Dar un pequeño tiempo para que la UI se actualice
        await Task.Delay(100);

        try
        {
            var token = state.CancellationTokenSource.Token;

            // Iniciar simulación de progreso en paralelo
            var progressTask = SimulateProgress(token);

            // Construir el objeto de filtros para enviar al servidor
            var serverFilter = new ServerFilter
            {
                // Filtrar _Selection de los ColumnFilters antes de enviar al servidor
                ColumnFilters = state.ColumnFilters
                    .Where(f => f.Key != "_Selection")
                    .ToDictionary(f => f.Key, f => f.Value),
                MultiValueFilters = new Dictionary<string, List<string>>(state.MultiValueFilters),
                StringFilters = new Dictionary<string, StringFilter>(),
                DateFilters = new Dictionary<string, DateFilter>(),
                BooleanFilters = new Dictionary<string, BooleanFilterType>(state.BooleanFilters),
                NumericFilters = new Dictionary<string, NumericFilter>(),
                SortColumn = state.SortColumn == "_Selection" ? null : state.SortColumn, // No enviar ordenamiento de selección al servidor
                SortAscending = state.SortAscending
            };

            // Convertir StringFilters al formato esperado
            foreach (var sf in state.StringFilters)
            {
                serverFilter.StringFilters[sf.Key] = new StringFilter
                {
                    Type = sf.Value.Type,
                    Value = sf.Value.Value
                };
            }

            // Convertir DateFilters al formato esperado
            foreach (var df in state.DateFilters)
            {
                serverFilter.DateFilters[df.Key] = new DateFilter
                {
                    Type = df.Value.Type,
                    StartDate = df.Value.From,
                    EndDate = df.Value.To
                };
            }

            // Convertir NumericFilters al formato esperado
            foreach (var nf in state.NumericFilters)
            {
                serverFilter.NumericFilters[nf.Key] = new NumericFilter
                {
                    Type = nf.Value.Type,
                    Value1 = nf.Value.Value1,
                    Value2 = nf.Value.Value2
                };
            }

            // Cargar datos con filtros Y cancellation token
            state.GridData = await EntidadService.GetEntidadDataAsync(NombreEntidad, serverFilter, token);

            // Limpiar IDs seleccionados que ya no existen en los datos filtrados
            CleanupOrphanedSelections();

            // Inicializar configuración de columnas si no existe
            if (state.GridData != null && state.ColumnConfigs.Count == 0)
            {
                InitializeColumnConfigs();
                // Aplicar configuración guardada después de inicializar columnas
                ApplyPendingConfiguration();
            }
        }
        catch (OperationCanceledException)
        {
            // No mostrar error cuando el usuario cancela
            // No limpiar GridData porque puede tener datos parciales
            state.ErrorMessage = null;
        }
        catch (Exception ex)
        {
            state.ErrorMessage = ex.Message;
            state.StackTrace = ex.StackTrace;
        }
        finally
        {
            state.IsLoading = false;
            state.ShowLoadingDialog = false;
            state.ProgressPercentage = 100;
            state.CancellationTokenSource?.Dispose();
            state.CancellationTokenSource = null;
            StateHasChanged();
        }
    }

