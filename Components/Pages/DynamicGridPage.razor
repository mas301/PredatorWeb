    private void FirstPage()
    {
        state.CurrentPage = 1;
    }

    private void PreviousPage()
    {
        if (state.CurrentPage > 1)
        {
            state.CurrentPage--;
        }
    }

    private void NextPage()
    {
        if (state.CurrentPage < state.TotalPages)
        {
            state.CurrentPage++;
        }
    }

    private void LastPage()
    {
        state.CurrentPage = state.TotalPages;
    }

    private void OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int newSize))
        {
            state.PageSize = newSize;
            state.CurrentPage = 1; // Volver a la primera página
        }
    }

    // ===== FILTRO Y ORDENAMIENTO POR SELECCIÓN =====

    private void OnSortSelection()
    {
        if (state.SortColumn == "_Selection")
        {
            // Alternar orden si ya está ordenando por selección
            state.SortAscending = !state.SortAscending;
        }
        else
        {
            // Primera vez ordenando por selección
            state.SortColumn = "_Selection";
            state.SortAscending = false; // Seleccionados primero
        }
    }



