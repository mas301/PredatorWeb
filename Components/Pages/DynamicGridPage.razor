    // ===== Métodos para configuración de columnas =====

    private void InitializeColumnConfigs()
    {
        if (state.GridData == null) return;

        state.ColumnConfigs.Clear();
        int order = 0;

        foreach (DataColumn column in state.GridData.Columns)
        {
            bool isNumeric = IsNumericColumn(column);
            state.ColumnConfigs.Add(new ColumnConfig
            {
                ColumnName = column.ColumnName,
                IsVisible = !ShouldHideColumn(column.ColumnName),
                DisplayOrder = order++,
                IsNumeric = isNumeric,
                ShowTotal = isNumeric  // Por defecto, las columnas numéricas muestran totales
            });
        }
    }

    private void CancelColumnConfig()
    {
        state.ShowColumnDialog = false;

        // Restaurar desde el backup (configuración antes de abrir el diálogo)
        if (tempColumnConfigsBackup != null)
        {
            state.ColumnConfigs.Clear();
            state.ColumnConfigs.AddRange(tempColumnConfigsBackup);
            tempColumnConfigsBackup = null;
        }
    }

    private void AcceptColumnConfig()
    {
        state.ShowColumnDialog = false;

        // Limpiar el backup ya que los cambios fueron aceptados
        tempColumnConfigsBackup = null;

        StateHasChanged();
    }

    private async Task HandleColumnConfigAccept(List<ColumnConfig> updatedConfigs)
    {
        state.ColumnConfigs = updatedConfigs;
        AcceptColumnConfig();

        // Guardar la configuración
        await SaveGridConfigurationAsync();

        // Forzar recarga de la UI para mostrar los cambios en los títulos
        StateHasChanged();
    }

    // Método actualizado para verificar si una columna debe ocultarse
    private bool ShouldHideColumn(string columnName)
    {
        // Si hay configuración de columnas, usar esa
        var config = state.ColumnConfigs.FirstOrDefault(c => c.ColumnName == columnName);
        if (config != null)
        {
            return !config.IsVisible;
        }

        // Comportamiento por defecto: ocultar columnas que terminan en "Id"
        return columnName.EndsWith("Id", StringComparison.OrdinalIgnoreCase);
    }

    // Método para obtener el orden de las columnas
    private IEnumerable<DataColumn> GetOrderedColumns()
    {
        if (state.GridData == null) yield break;

        if (state.ColumnConfigs.Count == 0)
        {
            // Si no hay configuración, usar orden original
            foreach (DataColumn column in state.GridData.Columns)
            {
                yield return column;
            }
        }
        else
        {
            // Usar orden configurado
            foreach (var config in state.ColumnConfigs.OrderBy(c => c.DisplayOrder))
            {
                var column = state.GridData.Columns[config.ColumnName];
                if (column != null)
                {
                    yield return column;
                }
            }
        }
    }

    // Métodos de filtros
    private bool HasActiveFilters()
    {
        return state.ColumnFilters.Any() 
            || state.MultiValueFilters.Any() 
            || state.DateFilters.Any() 
            || state.BooleanFilters.Any(f => f.Value != BooleanFilterType.All)
            || state.StringFilters.Any()
            || state.NumericFilters.Any(f => f.Value.Type != NumericFilterType.None);
    }

    private async Task ClearAllFilters()
    {
        state.ColumnFilters.Clear();
        state.MultiValueFilters.Clear();
        state.DateFilters.Clear();
        state.BooleanFilters.Clear();
        state.StringFilters.Clear();
        state.NumericFilters.Clear();
        // NOTA: NO limpiar state.SortColumn - mantener el ordenamiento actual

        // Recargar datos sin filtros (pero con el ordenamiento actual)
        await ReloadDataWithFiltersAsync();
    }

    private string GetFilterDescription()
    {
        var parts = new List<string>();

        // Filtros de texto
        foreach (var filter in state.ColumnFilters)
        {
            parts.Add($"{filter.Key} contenga '{filter.Value}'");
        }

        // Filtros multi-valor (checkboxes)
        foreach (var multiFilter in state.MultiValueFilters)
        {
            if (multiFilter.Value.Any())
            {
                var values = string.Join(", ", multiFilter.Value.Take(3));
                if (multiFilter.Value.Count > 3)
                {
                    values += $" y {multiFilter.Value.Count - 3} más";
                }
                parts.Add($"{multiFilter.Key} sea [{values}]");
            }
        }

        // Filtros de fecha
        foreach (var dateFilter in state.DateFilters)
        {
            var columnName = dateFilter.Key;
            var filterInfo = dateFilter.Value;

            switch (filterInfo.Type)
            {
                case DateFilterType.Today:
                    parts.Add($"{columnName} = Hoy");
                    break;
                case DateFilterType.Yesterday:
                    parts.Add($"{columnName} = Ayer");
                    break;
                case DateFilterType.ThisWeek:
                    parts.Add($"{columnName} = Esta Semana");
                    break;
                case DateFilterType.LastWeek:
                    parts.Add($"{columnName} = Semana Anterior");
                    break;
                case DateFilterType.ThisMonth:
                    parts.Add($"{columnName} = Este Mes");
                    break;
                case DateFilterType.LastMonth:
                    parts.Add($"{columnName} = Mes Anterior");
                    break;
                case DateFilterType.ThisYear:
                    parts.Add($"{columnName} = Este Año");
                    break;
                case DateFilterType.LastYear:
                    parts.Add($"{columnName} = Año Anterior");
                    break;
                case DateFilterType.CustomRange:
                    if (filterInfo.From.HasValue && filterInfo.To.HasValue)
                    {
                        parts.Add($"{columnName} entre {filterInfo.From.Value:dd/MM/yyyy} y {filterInfo.To.Value:dd/MM/yyyy}");
                    }
                    else if (filterInfo.From.HasValue)
                    {
                        parts.Add($"{columnName} >= {filterInfo.From.Value:dd/MM/yyyy}");
                    }
                    else if (filterInfo.To.HasValue)
                    {
                        parts.Add($"{columnName} <= {filterInfo.To.Value:dd/MM/yyyy}");
                    }
                    break;
            }
        }

        // Filtros booleanos
        foreach (var boolFilter in state.BooleanFilters.Where(f => f.Value != BooleanFilterType.All))
        {
            var columnName = boolFilter.Key;
            var filterType = boolFilter.Value;

            parts.Add(filterType == BooleanFilterType.Checked
                ? $"{columnName} = Sí"
                : $"{columnName} = No");
        }

        // Filtros de string con tipo
        foreach (var stringFilter in state.StringFilters)
        {
            var columnName = stringFilter.Key;
            var filterInfo = stringFilter.Value;
            var filterTypeText = filterInfo.Type switch
            {
                StringFilterType.Contains => "contenga",
                StringFilterType.StartsWith => "empiece con",
                StringFilterType.EndsWith => "finalice con",
                StringFilterType.Equals => "sea igual a",
                _ => "contenga"
            };
            parts.Add($"{columnName} {filterTypeText} '{filterInfo.Value}'");
        }

        // Filtros numéricos
        foreach (var numericFilter in state.NumericFilters.Where(f => f.Value.Type != NumericFilterType.None))
        {
            var columnName = numericFilter.Key;
            var filterInfo = numericFilter.Value;

            switch (filterInfo.Type)
            {
                case NumericFilterType.Equal:
                    parts.Add($"{columnName} = {filterInfo.Value1}");
                    break;
                case NumericFilterType.NotEqual:
                    parts.Add($"{columnName} ≠ {filterInfo.Value1}");
                    break;
                case NumericFilterType.GreaterThan:
                    parts.Add($"{columnName} > {filterInfo.Value1}");
                    break;
                case NumericFilterType.GreaterThanOrEqual:
                    parts.Add($"{columnName} ≥ {filterInfo.Value1}");
                    break;
                case NumericFilterType.LessThan:
                    parts.Add($"{columnName} < {filterInfo.Value1}");
                    break;
                case NumericFilterType.LessThanOrEqual:
                    parts.Add($"{columnName} ≤ {filterInfo.Value1}");
                    break;
                case NumericFilterType.Between:
                    parts.Add($"{columnName} entre {filterInfo.Value1} y {filterInfo.Value2}");
                    break;
            }
        }

        return string.Join(" y ", parts);
    }

    // ===== PERSISTENCIA DE CONFIGURACIÓN =====

    private async Task LoadGridConfigurationAsync()
    {
        try
        {
            if (string.IsNullOrEmpty(NombreEntidad))
                return;

            // Obtener la entidad para conseguir el nombre de la vista
            var entidad = EntidadService.GetEntidad(NombreEntidad);
            if (entidad == null)
                return;

            var configJson = await ConfigurationService.GetGridConfigurationAsync(entidad.NombreVista);
            if (string.IsNullOrEmpty(configJson))
                return;

            // Deserializar la configuración
            var config = System.Text.Json.JsonSerializer.Deserialize<Models.GridConfiguration>(configJson);
            if (config == null)
                return;

            // Migración: asegurar que columnas numéricas tengan ShowTotal = true por defecto
            // (para configuraciones antiguas que no tenían esta propiedad o la tenían en false)
            if (config.Columnas != null && state.GridData != null)
            {
                foreach (var colConfig in config.Columnas)
                {
                    var dataColumn = state.GridData.Columns.Cast<DataColumn>()
                        .FirstOrDefault(dc => dc.ColumnName == colConfig.Header);

                    if (dataColumn != null && IsNumericColumn(dataColumn) && !colConfig.ShowTotal)
                    {
                        // Si es una columna numérica y ShowTotal es false, es probable que sea
                        // una configuración antigua. Establecer en true por defecto.
                        colConfig.ShowTotal = true;
                    }
                }
            }

            // Guardar para aplicar la configuración de columnas después
            _pendingConfiguration = config;

            // Aplicar FILTROS inmediatamente (antes de decidir qué método de carga usar)

            // Aplicar filtros de texto (excluyendo _Selection que es solo en sesión)
            if (config.FiltrosTexto != null)
            {
                foreach (var filtro in config.FiltrosTexto)
                {
                    if (filtro.Key != "_Selection") // Ignorar _Selection si existiera en configuración antigua
                    {
                        state.ColumnFilters[filtro.Key] = filtro.Value;
                    }
                }
            }

            // Aplicar filtros de fecha
            if (config.FiltrosFecha != null)
            {
                foreach (var filtro in config.FiltrosFecha)
                {
                    state.DateFilters[filtro.Key] = (filtro.Value.Type, filtro.Value.From, filtro.Value.To);
                }
            }

            // Aplicar filtros booleanos
            if (config.FiltrosBool != null)
            {
                foreach (var filtro in config.FiltrosBool)
                {
                    state.BooleanFilters[filtro.Key] = filtro.Value;
                }
            }

            // Aplicar filtros multi-valor (checkboxes)
            if (config.FiltrosNumero != null)
            {
                foreach (var filtro in config.FiltrosNumero)
                {
                    state.MultiValueFilters[filtro.Key] = filtro.Value;
                }
            }

            // Aplicar ordenamiento (ignorar _Selection)
            if (!string.IsNullOrEmpty(config.ColumnaOrden) && config.ColumnaOrden != "_Selection")
            {
                state.SortColumn = config.ColumnaOrden;
                state.SortAscending = config.OrdenAscendente;
            }
        }
        catch (Exception ex)
        {
            // Log silencioso - si falla la carga de configuración, simplemente usar valores por defecto
            Console.WriteLine($"Error al cargar configuración: {ex.Message}");
        }
    }

    private void ApplyPendingConfiguration()
    {
        if (_pendingConfiguration == null)
            return;

        var config = _pendingConfiguration;

        // Aplicar solo configuración de columnas (los filtros ya se aplicaron en LoadGridConfigurationAsync)
        if (config.Columnas != null && config.Columnas.Count > 0)
        {
            foreach (var colConfig in config.Columnas)
            {
                var existingCol = state.ColumnConfigs.FirstOrDefault(c => c.ColumnName == colConfig.Header);
                if (existingCol != null)
                {
                    existingCol.IsVisible = colConfig.Visible;
                    existingCol.DisplayOrder = colConfig.Orden;
                    existingCol.CustomTitle = colConfig.CustomTitle;
                    existingCol.ShowTotal = colConfig.ShowTotal;
                }
            }

            // Reordenar según la configuración guardada
            state.ColumnConfigs = state.ColumnConfigs.OrderBy(c => c.DisplayOrder).ToList();
        }

        // Limpiar la configuración pendiente
        _pendingConfiguration = null;
    }

    private async Task SaveGridConfigurationAsync()
    {
        try
        {
            if (string.IsNullOrEmpty(NombreEntidad))
                return;

            // Obtener la entidad para conseguir el nombre de la vista
            var entidad = EntidadService.GetEntidad(NombreEntidad);
            if (entidad == null)
                return;

            // Construir la configuración
            var config = new Models.GridConfiguration
            {
                Columnas = state.ColumnConfigs.Select(c => new Models.ColumnConfiguration
                {
                    Header = c.ColumnName,
                    Orden = c.DisplayOrder,
                    Visible = c.IsVisible,
                    CustomTitle = c.CustomTitle,
                    ShowTotal = c.ShowTotal
                }).ToList(),

                // Filtrar _Selection de los filtros antes de guardar
                FiltrosTexto = state.ColumnFilters
                    .Where(f => f.Key != "_Selection")
                    .ToDictionary(f => f.Key, f => f.Value),

                FiltrosFecha = state.DateFilters.ToDictionary(
                    kvp => kvp.Key,
                    kvp => new Models.DateFilterConfig
                    {
                        Type = kvp.Value.Type,
                        From = kvp.Value.From,
                        To = kvp.Value.To
                    }
                ),

                FiltrosBool = new Dictionary<string, BooleanFilterType>(state.BooleanFilters),

                FiltrosNumero = new Dictionary<string, List<string>>(state.MultiValueFilters),

                OrdenAscendente = state.SortAscending,
                // No guardar _Selection como columna de orden
                ColumnaOrden = state.SortColumn == "_Selection" ? null : state.SortColumn
            };

            // Serializar a JSON
            var configJson = System.Text.Json.JsonSerializer.Serialize(config);

            // Guardar en la base de datos
            await ConfigurationService.SaveGridConfigurationAsync(entidad.NombreVista, configJson);
        }
        catch (Exception ex)
        {
            // Log silencioso - si falla el guardado, no interrumpir el cierre
            Console.WriteLine($"Error al guardar configuración: {ex.Message}");
        }
    }

