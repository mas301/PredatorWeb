@using System.Data
@using PredatorWeb.Models
@inject Services.EntidadService EntidadService
@implements IDisposable

<div class="grid-container">
    @if (state.ErrorMessage != null)
    {
        <div class="error-message">
            <h3>Error al cargar datos:</h3>
            <p>@state.ErrorMessage</p>
            @if (state.StackTrace != null)
            {
                <details>
                    <summary>Detalles del error</summary>
                    <pre>@state.StackTrace</pre>
                </details>
            }
        </div>
    }
    else if (state.IsLoading && state.ShowLoadingDialog)
    {
        <div class="loading-overlay">
            <div class="loading-dialog">
                <div class="loading-spinner"></div>
                <button class="btn-cancel-loading" @onclick="CancelLoading">
                    ✖ Cancelar
                </button>
            </div>
        </div>
    }
    else if (state.GridData != null && state.GridData.Rows.Count > 0)
    {
        <!-- Barra de herramientas -->
        <div class="toolbar">
            <button class="toolbar-btn" @onclick="OnIngresar" title="Ingresar">
                <span class="btn-icon">➕</span>
                <span class="btn-text">Ingresar</span>
            </button>
            <button class="toolbar-btn" @onclick="OnModificar" disabled="@(!CanModify())" title="Modificar">
                <span class="btn-icon">✏️</span>
                <span class="btn-text">Modificar</span>
            </button>
            <button class="toolbar-btn" @onclick="OnConsultar" disabled="@(!CanConsult())" title="Consultar">
                <span class="btn-icon">👁️</span>
                <span class="btn-text">Consultar</span>
            </button>
            <div class="toolbar-separator"></div>
            <button class="toolbar-btn" @onclick="OnDesactivar" disabled="@(!CanDeactivate())" title="Desactivar">
                <span class="btn-icon">🚫</span>
                <span class="btn-text">Desactivar</span>
            </button>
            <button class="toolbar-btn" @onclick="OnReactivar" disabled="@(!CanReactivate())" title="Reactivar">
                <span class="btn-icon">✅</span>
                <span class="btn-text">Reactivar</span>
            </button>
            <button class="toolbar-btn toolbar-btn-danger" @onclick="OnEliminar" disabled="@(!CanDelete())" title="Eliminar">
                <span class="btn-icon">🗑️</span>
                <span class="btn-text">Eliminar</span>
            </button>
            <div class="toolbar-separator"></div>
            <button class="toolbar-btn" @onclick="OnImprimir" title="Imprimir">
                <span class="btn-icon">🖨️</span>
                <span class="btn-text">Imprimir</span>
            </button>
            <button class="toolbar-btn" @onclick="OnImportar" title="Importar">
                <span class="btn-icon">📥</span>
                <span class="btn-text">Importar</span>
            </button>
            <button class="toolbar-btn" @onclick="OnExportar" title="Exportar">
                <span class="btn-icon">📤</span>
                <span class="btn-text">Exportar</span>
            </button>
            <div class="toolbar-separator"></div>
            <button class="toolbar-btn" @onclick="OnRefrescar" title="Refrescar">
                <span class="btn-icon">🔄</span>
                <span class="btn-text">Refrescar</span>
            </button>
            <button class="toolbar-btn" @onclick="OnColumnas" title="Columnas">
                <span class="btn-icon">📋</span>
                <span class="btn-text">Columnas</span>
            </button>
            <button class="toolbar-btn" @onclick="OnPropiedades" title="Propiedades">
                <span class="btn-icon">⚙️</span>
                <span class="btn-text">Propied</span>
            </button>
        </div>

        <!-- Barra de filtros -->
        @if (HasActiveFilters())
        {
            <div class="filter-bar">
                <button class="btn-clear-all-filters" @onclick="ClearAllFilters">
                    🗑️ Limpiar Filtro
                </button>
                <div class="filter-display">
                    <span class="filter-label">Filtros activos:</span>
                    <span class="filter-text">@GetFilterDescription()</span>
                </div>
            </div>
        }

        <div class="table-wrapper">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th class="checkbox-column">
                            <input type="checkbox"
                                   checked="@AreAllSelected()"
                                   @onchange="ToggleSelectAll" />
                         </th>
                        @foreach (DataColumn column in state.GridData.Columns)
                        {
                            @if (!ShouldHideColumn(column.ColumnName))
                            {
                                <th @onclick="@(() => ShowSortDialog(column.ColumnName))" class="@(IsNumericColumn(column) ? "text-right" : "")">
                                    @FormatColumnName(column.ColumnName)
                                    @if (state.SortColumn == column.ColumnName)
                                    {
                                        <span>@(state.SortAscending ? "▲" : "▼")</span>
                                    }
                                </th>
                            }
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (DataRow row in GetPagedData())
                    {
                        <tr class="@(IsRowSelected(row) ? "row-selected" : "")" 
                            @onclick="@(() => SelectSingleRow(row))" 
                            style="cursor: pointer;">
                            <td class="checkbox-column" @onclick:stopPropagation="true">
                                <input type="checkbox"
                                                   checked="@IsRowSelected(row)"
                                                   @onchange="@(e => ToggleRowSelection(row, e))" />
                                        </td>
                                       @foreach (DataColumn column in state.GridData.Columns)
                                       {
                                           @if (!ShouldHideColumn(column.ColumnName))
                                {
                                    <td class="@(IsNumericColumn(column) ? "text-right" : "")">
                                        @if (IsBooleanColumn(column))
                                        {
                                            <input type="checkbox" 
                                                   checked="@GetBooleanValue(row[column])" 
                                                   disabled 
                                                   style="cursor: default;" />
                                        }
                                        else
                                        {
                                            @FormatCellValue(row[column], column)
                                        }
                                    </td>
                                }
                            }
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="totals-row">
                        <td class="totals-label" colspan="@GetTotalLabelColspan()">
                            Total de registros: @GetFilteredData().Count()
                        </td>
                        @{
                            var columnsToSkip = GetTotalLabelColspan() - 1; // -1 porque ya contamos el checkbox
                            var columnIndex = 0;
                        }
                        @foreach (DataColumn column in state.GridData.Columns)
                        {
                            @if (!ShouldHideColumn(column.ColumnName))
                            {
                                columnIndex++;
                                @if (columnIndex > columnsToSkip)
                                {
                                    <td class="@(IsNumericColumn(column) ? "text-right" : "")">
                                        @if (IsNumericColumn(column))
                                        {
                                            @FormatTotal(GetColumnTotal(column))
                                        }
                                    </td>
                                }
                            }
                        }
                    </tr>
                </tfoot>
            </table>
        </div>

        <!-- Panel de pie eliminado, ahora el resumen está en tfoot -->
    }
    else
    {
        <div class="no-data-message">
            <p>No se encontraron datos para mostrar.</p>
            <p>Entidad: @NombreEntidad</p>
            <p>Datos cargados: @(state.GridData?.Rows.Count ?? 0) registros</p>
        </div>
    }

    <!-- Diálogo de ordenamiento -->
    @if (state.ShowSortDialog)
    {
        <div class="modal-overlay" @onclick="CancelSort">
            <div class="modal-dialog" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>Ordenar y Filtrar: @FormatColumnName(state.SelectedColumnForSort ?? "")</h3>
                </div>
                <div class="modal-body">
                    <div class="sort-section">
                        <h4>Ordenamiento</h4>
                        <div class="sort-options">
                            <label>
                                <input type="radio" name="sortOrder" value="asc" checked="@state.TempSortAscending" @onchange="@(() => state.TempSortAscending = true)" />
                                Ascendente (A-Z, 0-9)
                            </label>
                            <label>
                                <input type="radio" name="sortOrder" value="desc" checked="@(!state.TempSortAscending)" @onchange="@(() => state.TempSortAscending = false)" />
                                Descendente (Z-A, 9-0)
                            </label>
                        </div>
                    </div>

                    @if (IsSelectedColumnString())
                    {
                        <div class="filter-section">
                            <h4>Filtro de texto</h4>
                            <input type="text" 
                                   class="filter-input" 
                                   placeholder="Ingrese texto para filtrar..." 
                                   @bind="state.TempFilterValue" />
                            @if (!string.IsNullOrEmpty(state.TempFilterValue))
                            {
                                <button class="btn-clear-filter" @onclick="ClearTempFilter">✖ Limpiar</button>
                            }
                        </div>
                    }

                    @if (IsSelectedColumnDate())
                    {
                        <div class="filter-section">
                            <h4>Filtro de fecha</h4>
                            <select class="date-filter-select" @bind="state.TempDateFilterType" @bind:after="OnDateFilterTypeChanged">
                                <option value="@DateFilterType.None">Sin filtro</option>
                                <option value="@DateFilterType.Today">Hoy</option>
                                <option value="@DateFilterType.ThisWeek">Esta Semana</option>
                                <option value="@DateFilterType.ThisMonth">Este Mes</option>
                                <option value="@DateFilterType.ThisYear">Este Año</option>
                                <option value="@DateFilterType.CustomRange">Rango de fechas</option>
                            </select>

                            @if (state.TempDateFilterType == DateFilterType.CustomRange)
                            {
                                <div class="date-range-inputs">
                                    <div class="date-input-group">
                                        <label>Desde:</label>
                                        <input type="date" class="date-input" @bind="state.TempDateFrom" />
                                    </div>
                                    <div class="date-input-group">
                                        <label>Hasta:</label>
                                        <input type="date" class="date-input" @bind="state.TempDateTo" />
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @if (IsSelectedColumnBoolean())
                    {
                        <div class="filter-section">
                            <h4>Filtro de checkbox</h4>
                            <select class="boolean-filter-select" @bind="state.TempBooleanFilterType">
                                <option value="@BooleanFilterType.All">Todas</option>
                                <option value="@BooleanFilterType.Checked">Solo con check (✓)</option>
                                <option value="@BooleanFilterType.Unchecked">Solo sin check</option>
                            </select>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn-modal btn-cancel" @onclick="CancelSort">Cancelar</button>
                    <button class="btn-modal btn-accept" @onclick="AcceptSort">Aceptar</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string? NombreEntidad { get; set; }

    // Estado encapsulado de la grilla
    private GridPageState state = new();

    public void Dispose()
    {
        state.Dispose();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(NombreEntidad))
        {
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        if (string.IsNullOrEmpty(NombreEntidad))
            return;

        // Cancelar cualquier carga anterior en progreso
        state.CancellationTokenSource?.Cancel();
        state.CancellationTokenSource?.Dispose();
        state.CancellationTokenSource = new CancellationTokenSource();

        state.IsLoading = true;
        state.ShowLoadingDialog = false;
        state.ErrorMessage = null;
        state.StackTrace = null;
        state.ProgressPercentage = 0;
        state.LoadingMessage = "Preparando consulta...";

        try
        {
            var token = state.CancellationTokenSource.Token;

            // Iniciar temporizador para mostrar diálogo después de 5 segundos
            var showDialogTask = Task.Delay(5000, token).ContinueWith(t =>
            {
                if (!t.IsCanceled && state.IsLoading)
                {
                    state.ShowLoadingDialog = true;
                    InvokeAsync(StateHasChanged);
                }
            }, TaskScheduler.Default);

            // Iniciar la carga de datos
            var loadTask = EntidadService.GetEntidadDataAsync(NombreEntidad);

            // Esperar a que termine la carga
            state.GridData = await loadTask;

            state.SelectedRows.Clear();
        }
        catch (OperationCanceledException)
        {
            state.ErrorMessage = "La carga de datos fue cancelada por el usuario.";
            state.GridData = null;
        }
        catch (Exception ex)
        {
            state.ErrorMessage = ex.Message;
            state.StackTrace = ex.StackTrace;
        }
        finally
        {
            state.IsLoading = false;
            state.ShowLoadingDialog = false;
            state.CancellationTokenSource?.Dispose();
            state.CancellationTokenSource = null;
        }
    }

    private async Task SimulateProgress(CancellationToken token)
    {
        for (int i = 30; i < 85; i += 5)
        {
            if (token.IsCancellationRequested)
                return;

            state.ProgressPercentage = i;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(400, token);
        }
    }

    private async Task UpdateProgress(int percentage, string message, CancellationToken token)
    {
        token.ThrowIfCancellationRequested();
        state.ProgressPercentage = percentage;
        state.LoadingMessage = message;
        await InvokeAsync(StateHasChanged);
    }

    private void CancelLoading()
    {
        state.CancellationTokenSource?.Cancel();
    }

    private IEnumerable<DataRow> GetPagedData()
    {
        return GetFilteredData();
    }

    private IEnumerable<DataRow> GetFilteredData()
    {
        if (state.GridData == null) return Enumerable.Empty<DataRow>();

        var rows = state.GridData.AsEnumerable();

        // Aplicar filtros de texto
        foreach (var filter in state.ColumnFilters)
        {
            var columnName = filter.Key;
            var filterValue = filter.Value;

            if (!string.IsNullOrWhiteSpace(filterValue))
            {
                rows = rows.Where(r => 
                {
                    var cellValue = r[columnName];
                    if (cellValue == null || cellValue == DBNull.Value)
                        return false;
                    return cellValue.ToString()?.Contains(filterValue, StringComparison.OrdinalIgnoreCase) ?? false;
                });
            }
        }

        // Aplicar filtros de fecha
        foreach (var filter in state.DateFilters)
        {
            var columnName = filter.Key;
            var dateFilter = filter.Value;

            if (dateFilter.Type != DateFilterType.None)
            {
                rows = rows.Where(r => ApplyDateFilter(r[columnName], dateFilter));
            }
        }

        // Aplicar filtros de booleanos
        foreach (var filter in state.BooleanFilters)
        {
            var columnName = filter.Key;
            var booleanFilter = filter.Value;

            if (booleanFilter != BooleanFilterType.All)
            {
                rows = rows.Where(r => ApplyBooleanFilter(r[columnName], booleanFilter));
            }
        }

        // Aplicar ordenamiento
        if (!string.IsNullOrEmpty(state.SortColumn))
        {
            rows = state.SortAscending 
                ? rows.OrderBy(r => r[state.SortColumn]) 
                : rows.OrderByDescending(r => r[state.SortColumn]);
        }

        // Retornar todos los datos sin paginación
        return rows.ToList();
    }

    private void SortByColumn(string columnName)
    {
        if (state.SortColumn == columnName)
        {
            state.SortAscending = !state.SortAscending;
        }
        else
        {
            state.SortColumn = columnName;
            state.SortAscending = true;
        }
    }

    private void ShowSortDialog(string columnName)
    {
        state.SelectedColumnForSort = columnName;
        // Si la columna ya está ordenada, usar el mismo orden, sino ascendente por defecto
        if (state.SortColumn == columnName)
        {
            state.TempSortAscending = state.SortAscending;
        }
        else
        {
            state.TempSortAscending = true;
        }

        // Cargar el filtro de texto existente para esta columna si existe
        if (state.ColumnFilters.ContainsKey(columnName))
        {
            state.TempFilterValue = state.ColumnFilters[columnName];
        }
        else
        {
            state.TempFilterValue = "";
        }

        // Cargar el filtro de fecha existente para esta columna si existe
        if (state.DateFilters.ContainsKey(columnName))
        {
            var dateFilter = state.DateFilters[columnName];
            state.TempDateFilterType = dateFilter.Type;
            state.TempDateFrom = dateFilter.From;
            state.TempDateTo = dateFilter.To;
        }
        else
        {
            state.TempDateFilterType = DateFilterType.None;
            state.TempDateFrom = null;
            state.TempDateTo = null;
        }

        // Cargar el filtro booleano existente para esta columna si existe
        if (state.BooleanFilters.ContainsKey(columnName))
        {
            state.TempBooleanFilterType = state.BooleanFilters[columnName];
        }
        else
        {
            state.TempBooleanFilterType = BooleanFilterType.All;
        }

        state.ShowSortDialog = true;
    }

    private void AcceptSort()
    {
        if (!string.IsNullOrEmpty(state.SelectedColumnForSort))
        {
            state.SortColumn = state.SelectedColumnForSort;
            state.SortAscending = state.TempSortAscending;

            // Guardar o eliminar el filtro según el valor
            if (IsSelectedColumnString())
            {
                if (!string.IsNullOrWhiteSpace(state.TempFilterValue))
                {
                    state.ColumnFilters[state.SelectedColumnForSort] = state.TempFilterValue;
                }
                else
                {
                    state.ColumnFilters.Remove(state.SelectedColumnForSort);
                }
            }

            // Guardar o eliminar el filtro de fecha
            if (IsSelectedColumnDate())
            {
                if (state.TempDateFilterType != DateFilterType.None)
                {
                    state.DateFilters[state.SelectedColumnForSort] = (state.TempDateFilterType, state.TempDateFrom, state.TempDateTo);
                }
                else
                {
                    state.DateFilters.Remove(state.SelectedColumnForSort);
                }
            }

            // Guardar o eliminar el filtro booleano
            if (IsSelectedColumnBoolean())
            {
                if (state.TempBooleanFilterType != BooleanFilterType.All)
                {
                    state.BooleanFilters[state.SelectedColumnForSort] = state.TempBooleanFilterType;
                }
                else
                {
                    state.BooleanFilters.Remove(state.SelectedColumnForSort);
                }
            }
        }
        state.ShowSortDialog = false;
    }

    private void CancelSort()
    {
        state.ShowSortDialog = false;
    }

    private bool IsSelectedColumnString()
    {
        if (state.GridData == null || string.IsNullOrEmpty(state.SelectedColumnForSort))
            return false;

        var column = state.GridData.Columns[state.SelectedColumnForSort];
        return column != null && column.DataType == typeof(string);
    }

    private bool IsSelectedColumnDate()
    {
        if (state.GridData == null || string.IsNullOrEmpty(state.SelectedColumnForSort))
            return false;

        var column = state.GridData.Columns[state.SelectedColumnForSort];
        return column != null && (column.DataType == typeof(DateTime) || column.DataType == typeof(DateTime?));
    }

    private bool IsSelectedColumnBoolean()
    {
        if (state.GridData == null || string.IsNullOrEmpty(state.SelectedColumnForSort))
            return false;

        var column = state.GridData.Columns[state.SelectedColumnForSort];
        return column != null && column.DataType == typeof(bool);
    }

    private void ClearTempFilter()
    {
        state.TempFilterValue = "";
    }

    private bool ApplyDateFilter(object cellValue, (DateFilterType Type, DateTime? From, DateTime? To) filter)
    {
        if (cellValue == null || cellValue == DBNull.Value)
            return false;

        if (!DateTime.TryParse(cellValue.ToString(), out DateTime dateValue))
            return false;

        var today = DateTime.Today;

        switch (filter.Type)
        {
            case DateFilterType.Today:
                return dateValue.Date == today;

            case DateFilterType.ThisWeek:
                var startOfWeek = today.AddDays(-(int)today.DayOfWeek);
                var endOfWeek = startOfWeek.AddDays(7);
                return dateValue.Date >= startOfWeek && dateValue.Date < endOfWeek;

            case DateFilterType.ThisMonth:
                return dateValue.Year == today.Year && dateValue.Month == today.Month;

            case DateFilterType.ThisYear:
                return dateValue.Year == today.Year;

            case DateFilterType.CustomRange:
                if (filter.From.HasValue && dateValue.Date < filter.From.Value.Date)
                    return false;
                if (filter.To.HasValue && dateValue.Date > filter.To.Value.Date)
                    return false;
                return true;

            default:
                return true;
        }
    }

    private void OnDateFilterTypeChanged()
    {
        // Si se selecciona rango de fechas y ambas fechas son nulas, inicializar con la fecha de hoy
        if (state.TempDateFilterType == DateFilterType.CustomRange)
        {
            if (!state.TempDateFrom.HasValue && !state.TempDateTo.HasValue)
            {
                state.TempDateFrom = DateTime.Today;
                state.TempDateTo = DateTime.Today;
            }
        }
    }

    private bool ApplyBooleanFilter(object cellValue, BooleanFilterType filterType)
    {
        if (cellValue == null || cellValue == DBNull.Value)
            return filterType == BooleanFilterType.Unchecked; // null se considera como false/sin check

        if (bool.TryParse(cellValue.ToString(), out bool boolValue))
        {
            return filterType switch
            {
                BooleanFilterType.Checked => boolValue == true,
                BooleanFilterType.Unchecked => boolValue == false,
                BooleanFilterType.All => true,
                _ => true
            };
        }

        return false;
    }

    private bool ShouldHideColumn(string columnName)
    {
        // Ocultar columnas que terminan en "Id"
        return columnName.EndsWith("Id", StringComparison.OrdinalIgnoreCase);
    }

    private string FormatColumnName(string columnName)
    {
        if (string.IsNullOrEmpty(columnName))
            return columnName;

        // Agregar espacio antes de cada letra mayúscula (excepto la primera)
        var result = new System.Text.StringBuilder();

        for (int i = 0; i < columnName.Length; i++)
        {
            if (i > 0 && char.IsUpper(columnName[i]) && !char.IsUpper(columnName[i - 1]))
            {
                result.Append(' ');
            }
            result.Append(columnName[i]);
        }

        return result.ToString();
    }

    private bool IsNumericColumn(DataColumn column)
    {
        return column.DataType == typeof(decimal) ||
               column.DataType == typeof(double) ||
               column.DataType == typeof(float) ||
               column.DataType == typeof(int) ||
               column.DataType == typeof(long) ||
               column.DataType == typeof(short);
    }

    private bool IsBooleanColumn(DataColumn column)
    {
        return column.DataType == typeof(bool);
    }

    private bool GetBooleanValue(object value)
    {
        if (value == null || value == DBNull.Value)
            return false;

        return Convert.ToBoolean(value);
    }

    private string FormatCellValue(object value, DataColumn column)
    {
        if (value == null || value == DBNull.Value)
            return "";

        // Formatear fechas en formato corto sin hora
        if (column.DataType == typeof(DateTime))
        {
            return ((DateTime)value).ToString("d");
        }
        // Formatear decimales a 2 decimales
        else if (column.DataType == typeof(decimal))
        {
            return ((decimal)value).ToString("N2");
        }
        else if (column.DataType == typeof(double))
        {
            return ((double)value).ToString("N2");
        }
        else if (column.DataType == typeof(float))
        {
            return ((float)value).ToString("N2");
        }
        // Formatear enteros sin decimales pero con separador de miles
        else if (column.DataType == typeof(int))
        {
            return ((int)value).ToString("N0");
        }
        else if (column.DataType == typeof(long))
        {
            return ((long)value).ToString("N0");
        }
        else if (column.DataType == typeof(short))
        {
            return ((short)value).ToString("N0");
        }

        return value.ToString() ?? "";
    }

    private decimal GetColumnTotal(DataColumn column)
    {
        if (!IsNumericColumn(column))
            return 0;

        var filteredRows = GetFilteredData();
        decimal total = 0;

        foreach (var row in filteredRows)
        {
            var cellValue = row[column];
            if (cellValue != null && cellValue != DBNull.Value)
            {
                try
                {
                    total += Convert.ToDecimal(cellValue);
                }
                catch
                {
                    // Ignorar valores que no se puedan convertir
                }
            }
        }

        return total;
    }

    private string FormatTotal(decimal total)
    {
        return total.ToString("N2");
    }

    private int GetTotalLabelColspan()
    {
        // Obtener el número de columnas visibles (no ocultas)
        if (state.GridData == null) return 1;

        var visibleColumnsCount = state.GridData.Columns.Cast<DataColumn>()
            .Count(col => !ShouldHideColumn(col.ColumnName));

        // El label ocupará como máximo 3 columnas (checkbox + 2 columnas de datos)
        // o la mitad de las columnas visibles, lo que sea menor
        var maxColspan = Math.Min(3, Math.Max(1, visibleColumnsCount / 2));

        // +1 para incluir la columna del checkbox
        return maxColspan + 1;
    }

    private bool IsRowSelected(DataRow row) => state.SelectedRows.Contains(row);

    private void ToggleRowSelection(DataRow row, ChangeEventArgs e)
    {
        if (e.Value is bool isChecked && isChecked)
        {
            state.SelectedRows.Add(row);
        }
        else
        {
            state.SelectedRows.Remove(row);
        }
    }

    private void SelectSingleRow(DataRow row)
    {
        // Deseleccionar todas las filas
        state.SelectedRows.Clear();
        // Seleccionar solo la fila clickeada
        state.SelectedRows.Add(row);
    }

    private bool AreAllSelected()
    {
        var pagedRows = GetPagedData().ToList();
        return pagedRows.Count > 0 && pagedRows.All(state.SelectedRows.Contains);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var isChecked = e.Value is bool value && value;

        foreach (var row in GetPagedData())
        {
            if (isChecked)
            {
                state.SelectedRows.Add(row);
            }
            else
            {
                state.SelectedRows.Remove(row);
            }
        }
    }

    // Toolbar methods
    private bool HasSelection() => state.SelectedRows.Count > 0;

    private bool CanModify()
    {
        // Solo permitir modificar si hay exactamente UN registro seleccionado
        if (state.SelectedRows.Count != 1) return false;

        var row = state.SelectedRows.First();

        // Verificar si el registro está anulado
        if (row.Table.Columns.Contains("Anulado"))
        {
            var anulado = row["Anulado"];
            if (anulado != null && anulado != DBNull.Value && Convert.ToBoolean(anulado))
            {
                return false; // Si el checkbox está seleccionado (anulado = true), no permitir modificar
            }
        }

        return true;
    }

    private bool CanConsult()
    {
        // Solo permitir consultar si hay exactamente UN registro seleccionado
        return state.SelectedRows.Count == 1;
    }

    private bool CanDeactivate()
    {
        if (state.SelectedRows.Count == 0) return false;

        // Verificar que TODOS los registros seleccionados NO estén anulados
        foreach (var row in state.SelectedRows)
        {
            if (row.Table.Columns.Contains("Anulado"))
            {
                var anulado = row["Anulado"];
                if (anulado != null && anulado != DBNull.Value && Convert.ToBoolean(anulado))
                {
                    return false; // Si encontramos algún registro anulado, no permitir desactivar
                }
            }
        }

        return true; // Todos los registros NO están anulados
    }

    private bool CanReactivate()
    {
        if (state.SelectedRows.Count == 0) return false;

        // Verificar que TODOS los registros seleccionados estén anulados
        foreach (var row in state.SelectedRows)
        {
            if (row.Table.Columns.Contains("Anulado"))
            {
                var anulado = row["Anulado"];
                if (anulado == null || anulado == DBNull.Value || !Convert.ToBoolean(anulado))
                {
                    return false; // Si encontramos algún registro NO anulado, no permitir reactivar
                }
            }
            else
            {
                return false; // Si no existe la columna Anulado, no permitir reactivar
            }
        }

        return true; // Todos los registros están anulados
    }

    private bool CanDelete()
    {
        if (state.SelectedRows.Count == 0) return false;

        // Verificar que TODOS los registros seleccionados estén anulados
        foreach (var row in state.SelectedRows)
        {
            if (row.Table.Columns.Contains("Anulado"))
            {
                var anulado = row["Anulado"];
                if (anulado == null || anulado == DBNull.Value || !Convert.ToBoolean(anulado))
                {
                    return false; // Si encontramos algún registro NO anulado, no permitir eliminar
                }
            }
            else
            {
                return false; // Si no existe la columna Anulado, no permitir eliminar
            }
        }

        return true; // Todos los registros están anulados
    }

