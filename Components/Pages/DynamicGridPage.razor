@using System.Data
@inject Services.EntidadService EntidadService

<div class="grid-container">
    @if (errorMessage != null)
    {
        <div class="error-message">
            <h3>Error al cargar datos:</h3>
            <p>@errorMessage</p>
            @if (stackTrace != null)
            {
                <details>
                    <summary>Detalles del error</summary>
                    <pre>@stackTrace</pre>
                </details>
            }
        </div>
    }
    else if (isLoading)
    {
        <div class="loading-message">
            <p>Cargando datos para: @NombreEntidad...</p>
        </div>
    }
    else if (gridData != null && gridData.Rows.Count > 0)
    {
        <div class="grid-controls">
            <div class="pagination-info">
                Mostrando @((currentPage - 1) * pageSize + 1) - @Math.Min(currentPage * pageSize, totalRecords) de @totalRecords registros
            </div>
            <div class="pagination-controls">
                <button class="btn-page" @onclick="FirstPage" disabled="@(currentPage == 1)">⏮️</button>
                <button class="btn-page" @onclick="PreviousPage" disabled="@(currentPage == 1)">◀️</button>
                <span class="page-info">Página @currentPage de @totalPages</span>
                <button class="btn-page" @onclick="NextPage" disabled="@(currentPage == totalPages)">▶️</button>
                <button class="btn-page" @onclick="LastPage" disabled="@(currentPage == totalPages)">⏭️</button>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th class="checkbox-column">
                            <input type="checkbox"
                                   checked="@AreAllSelected()"
                                   @onchange="ToggleSelectAll" />
                        </th>
                        @foreach (DataColumn column in gridData.Columns)
                        {
                            @if (!ShouldHideColumn(column.ColumnName))
                            {
                                <th @onclick="@(() => SortByColumn(column.ColumnName))" class="@(IsNumericColumn(column) ? "text-right" : "")">
                                    @FormatColumnName(column.ColumnName)
                                    @if (sortColumn == column.ColumnName)
                                    {
                                        <span>@(sortAscending ? "▲" : "▼")</span>
                                    }
                                </th>
                            }
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (DataRow row in GetPagedData())
                    {
                        <tr class="@(IsRowSelected(row) ? "row-selected" : "")">
                            <td class="checkbox-column">
                                <input type="checkbox"
                                       checked="@IsRowSelected(row)"
                                       @onchange="@(e => ToggleRowSelection(row, e))" />
                            </td>
                            @foreach (DataColumn column in gridData.Columns)
                            {
                                @if (!ShouldHideColumn(column.ColumnName))
                                {
                                    <td class="@(IsNumericColumn(column) ? "text-right" : "")">
                                        @FormatCellValue(row[column], column)
                                    </td>
                                }
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="no-data-message">
            <p>No se encontraron datos para mostrar.</p>
            <p>Entidad: @NombreEntidad</p>
            <p>Datos cargados: @(gridData?.Rows.Count ?? 0) registros</p>
        </div>
    }
</div>

@code {
    [Parameter]
    public string? NombreEntidad { get; set; }

    private DataTable? gridData;
    private bool isLoading = true;
    private string? errorMessage;
    private string? stackTrace;

    // Paginación
    private int currentPage = 1;
    private int pageSize = 20;
    private int totalRecords = 0;
    private int totalPages = 0;

    // Ordenamiento
    private string? sortColumn;
    private bool sortAscending = true;

    // Selección de filas
    private readonly HashSet<DataRow> selectedRows = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(NombreEntidad))
        {
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        if (string.IsNullOrEmpty(NombreEntidad))
            return;

        isLoading = true;
        errorMessage = null;
        stackTrace = null;

        try
        {
            gridData = await EntidadService.GetEntidadDataAsync(NombreEntidad);
            selectedRows.Clear();
            totalRecords = gridData?.Rows.Count ?? 0;
            totalPages = (int)Math.Ceiling(totalRecords / (double)pageSize);
            currentPage = 1;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            stackTrace = ex.StackTrace;
        }
        finally
        {
            isLoading = false;
        }
    }

    private IEnumerable<DataRow> GetPagedData()
    {
        if (gridData == null) return Enumerable.Empty<DataRow>();

        var rows = gridData.AsEnumerable();

        // Aplicar ordenamiento
        if (!string.IsNullOrEmpty(sortColumn))
        {
            rows = sortAscending 
                ? rows.OrderBy(r => r[sortColumn]) 
                : rows.OrderByDescending(r => r[sortColumn]);
        }

        // Aplicar paginación
        return rows
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize);
    }

    private void SortByColumn(string columnName)
    {
        if (sortColumn == columnName)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = columnName;
            sortAscending = true;
        }
    }

    private void FirstPage()
    {
        currentPage = 1;
    }

    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
        }
    }

    private void NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
        }
    }

    private void LastPage()
    {
        currentPage = totalPages;
    }

    private bool ShouldHideColumn(string columnName)
    {
        // Ocultar columnas que terminan en "Id"
        return columnName.EndsWith("Id", StringComparison.OrdinalIgnoreCase);
    }

    private string FormatColumnName(string columnName)
    {
        if (string.IsNullOrEmpty(columnName))
            return columnName;

        // Agregar espacio antes de cada letra mayúscula (excepto la primera)
        var result = new System.Text.StringBuilder();

        for (int i = 0; i < columnName.Length; i++)
        {
            if (i > 0 && char.IsUpper(columnName[i]) && !char.IsUpper(columnName[i - 1]))
            {
                result.Append(' ');
            }
            result.Append(columnName[i]);
        }

        return result.ToString();
    }

    private bool IsNumericColumn(DataColumn column)
    {
        return column.DataType == typeof(decimal) ||
               column.DataType == typeof(double) ||
               column.DataType == typeof(float) ||
               column.DataType == typeof(int) ||
               column.DataType == typeof(long) ||
               column.DataType == typeof(short);
    }

    private string FormatCellValue(object value, DataColumn column)
    {
        if (value == null || value == DBNull.Value)
            return "";

        // Formatear fechas en formato corto sin hora
        if (column.DataType == typeof(DateTime))
        {
            return ((DateTime)value).ToString("d");
        }
        // Formatear decimales a 2 decimales
        else if (column.DataType == typeof(decimal))
        {
            return ((decimal)value).ToString("N2");
        }
        else if (column.DataType == typeof(double))
        {
            return ((double)value).ToString("N2");
        }
        else if (column.DataType == typeof(float))
        {
            return ((float)value).ToString("N2");
        }
        // Formatear enteros sin decimales pero con separador de miles
        else if (column.DataType == typeof(int))
        {
            return ((int)value).ToString("N0");
        }
        else if (column.DataType == typeof(long))
        {
            return ((long)value).ToString("N0");
        }
        else if (column.DataType == typeof(short))
        {
            return ((short)value).ToString("N0");
        }

        return value.ToString() ?? "";
    }

    private bool IsRowSelected(DataRow row) => selectedRows.Contains(row);

    private void ToggleRowSelection(DataRow row, ChangeEventArgs e)
    {
        if (e.Value is bool isChecked && isChecked)
        {
            selectedRows.Add(row);
        }
        else
        {
            selectedRows.Remove(row);
        }
    }

    private bool AreAllSelected()
    {
        var pagedRows = GetPagedData().ToList();
        return pagedRows.Count > 0 && pagedRows.All(selectedRows.Contains);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var isChecked = e.Value is bool value && value;

        foreach (var row in GetPagedData())
        {
            if (isChecked)
            {
                selectedRows.Add(row);
            }
            else
            {
                selectedRows.Remove(row);
            }
        }
    }
}
