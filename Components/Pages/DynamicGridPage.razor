    private bool HasActiveFilter(string columnName)
    {
        // Verificar si hay filtro de texto
        if (state.ColumnFilters.ContainsKey(columnName) && !string.IsNullOrWhiteSpace(state.ColumnFilters[columnName]))
            return true;

        // Verificar si hay filtro multi-valor
        if (state.MultiValueFilters.ContainsKey(columnName) && state.MultiValueFilters[columnName].Any())
            return true;

        // Verificar si hay filtro de string con tipo
        if (state.StringFilters.ContainsKey(columnName) && !string.IsNullOrWhiteSpace(state.StringFilters[columnName].Value))
            return true;

        // Verificar si hay filtro de fecha
        if (state.DateFilters.ContainsKey(columnName) && state.DateFilters[columnName].Type != DateFilterType.None)
            return true;

        // Verificar si hay filtro booleano
        if (state.BooleanFilters.ContainsKey(columnName) && state.BooleanFilters[columnName] != BooleanFilterType.All)
            return true;

        // Verificar si hay filtro numérico
        if (state.NumericFilters.ContainsKey(columnName) && state.NumericFilters[columnName].Type != NumericFilterType.None)
            return true;

        return false;
    }

    private bool GetBooleanValue(object value)
    {
        if (value == null || value == DBNull.Value)
            return false;

        return Convert.ToBoolean(value);
    }

    private string FormatCellValue(object value, DataColumn column)
    {
        if (value == null || value == DBNull.Value)
            return "";

        // Formatear fechas en formato corto sin hora
        if (column.DataType == typeof(DateTime))
        {
            return ((DateTime)value).ToString("d");
        }
        // Formatear decimales a 2 decimales
        else if (column.DataType == typeof(decimal))
        {
            return ((decimal)value).ToString("N2");
        }
        else if (column.DataType == typeof(double))
        {
            return ((double)value).ToString("N2");
        }
        else if (column.DataType == typeof(float))
        {
            return ((float)value).ToString("N2");
        }
        // Formatear enteros sin decimales pero con separador de miles
        else if (column.DataType == typeof(int))
        {
            return ((int)value).ToString("N0");
        }
        else if (column.DataType == typeof(long))
        {
            return ((long)value).ToString("N0");
        }
        else if (column.DataType == typeof(short))
        {
            return ((short)value).ToString("N0");
        }

        return value.ToString() ?? "";
    }

    // Sobrecarga para formatear valores sin columna (para vista previa)
    private string FormatCellValue(object value)
    {
        if (value == null || value == DBNull.Value)
            return "";

        // Formatear fechas
        if (value is DateTime dateValue)
        {
            return dateValue.ToString("dd/MM/yyyy");
        }
        // Formatear decimales
        else if (value is decimal decimalValue)
        {
            return decimalValue.ToString("N2");
        }
        else if (value is double doubleValue)
        {
            return doubleValue.ToString("N2");
        }
        else if (value is float floatValue)
        {
            return floatValue.ToString("N2");
        }
        // Formatear enteros
        else if (value is int intValue)
        {
            return intValue.ToString("N0");
        }
        else if (value is long longValue)
        {
            return longValue.ToString("N0");
        }
        else if (value is short shortValue)
        {
            return shortValue.ToString("N0");
        }
        // Formatear booleanos
        else if (value is bool boolValue)
        {
            return boolValue ? "Sí" : "No";
        }

        return value.ToString() ?? "";
    }

    private decimal GetPrintPreviewColumnTotal(DataColumn column)
    {
        if (!IsNumericColumn(column) || state.PrintPreviewData == null)
