    private async void OnImprimir()
    {
        if (state.GridData == null || state.GridData.Rows.Count == 0)
            return;

        try
        {
            var previewTable = new DataTable();

            foreach (var column in GetOrderedColumns())
            {
                if (!ShouldHideColumn(column.ColumnName))
                {
                    var displayName = GetColumnDisplayName(column.ColumnName);
                    previewTable.Columns.Add(displayName, column.DataType);
                }
            }

            foreach (DataRow row in GetFilteredData())
            {
                var newRow = previewTable.NewRow();
                int colIndex = 0;
                foreach (var column in GetOrderedColumns())
                {
                    if (!ShouldHideColumn(column.ColumnName))
                    {
                        newRow[colIndex++] = row[column.ColumnName];
                    }
                }
                previewTable.Rows.Add(newRow);
            }

            var entidad = NombreEntidad != null ? EntidadService.GetEntidad(NombreEntidad) : null;
            var title = entidad?.NombrePlural ?? NombreEntidad ?? "Vista Previa";

            if (OpenPrintPreviewTab.HasDelegate)
            {
                // Abrir como pestaña en MainPage
                await OpenPrintPreviewTab.InvokeAsync((title, previewTable));
            }
            else
            {
                // Fallback: usar el modal interno
                state.PrintPreviewData = previewTable;
                state.ShowPrintPreview = true;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            state.ErrorMessage = $"Error al preparar la vista previa: {ex.Message}";
            StateHasChanged();
        }
    }

