    private int GetTotalLabelColspan()
    {
        // Obtener el número de columnas visibles (no ocultas)
        if (state.GridData == null) return 1;

        var visibleColumnsCount = state.GridData.Columns.Cast<DataColumn>()
            .Count(col => !ShouldHideColumn(col.ColumnName));

        // El label ocupará más columnas cuando hay paginación para evitar wrap
        // Mínimo 4 columnas, o hasta un tercio de las columnas visibles
        var maxColspan = state.ShowPagination 
            ? Math.Min(6, Math.Max(4, visibleColumnsCount / 3))
            : Math.Min(3, Math.Max(1, visibleColumnsCount / 2));

        // +1 para incluir la columna del checkbox
        return maxColspan + 1;
    }

    private void ToggleRowSelection(DataRow row, ChangeEventArgs e)
    {
        var id = GetRowId(row);
        if (id == null)
        {
            return;
        }

        if (e.Value is bool isChecked && isChecked)
        {
            state.SelectedRowIds.Add(id);
        }
        else
        {
            state.SelectedRowIds.Remove(id);
        }

        StateHasChanged();
    }

    private void SelectSingleRow(DataRow row)
    {
        var id = GetRowId(row);
        if (id == null) return;

        // Deseleccionar todas las filas
        state.SelectedRowIds.Clear();
        // Seleccionar solo la fila clickeada
        state.SelectedRowIds.Add(id);
    }

    private bool AreAllSelected()
    {
        var pagedRows = GetPagedData().ToList();
        return pagedRows.Count > 0 && pagedRows.All(row => IsRowSelected(row));
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var isChecked = e.Value is bool value && value;

        if (isChecked)
        {
            // Agregar todas las filas de la página actual
            foreach (var row in GetPagedData())
            {
                var id = GetRowId(row);
                if (id != null)
                {
                    state.SelectedRowIds.Add(id);
                }
            }
        }
        else
        {
            // Al deseleccionar:
            // Si todas las filas de esta página estaban seleccionadas, limpiar TODAS las selecciones (incluyendo otras páginas)
            // Si no, solo remover las de esta página
            var pagedRows = GetPagedData().ToList();
            var allPageRowsWereSelected = pagedRows.Count > 0 && pagedRows.All(row => IsRowSelected(row));

            if (allPageRowsWereSelected)
            {
                // Limpiar todas las selecciones globalmente
                state.SelectedRowIds.Clear();
            }
            else
            {
                // Solo remover las filas de esta página
                foreach (var row in pagedRows)
                {
                    var id = GetRowId(row);
                    if (id != null)
                    {
                        state.SelectedRowIds.Remove(id);
                    }
                }
            }
        }

        // Forzar actualización de la UI
        StateHasChanged();
    }

    // Toolbar methods
    private bool HasSelection() => state.SelectedRowIds.Count > 0;

    private bool CanModify()
    {
        // Solo permitir modificar si hay exactamente UN registro seleccionado
        if (state.SelectedRowIds.Count != 1) return false;

        var row = GetSelectedRow();
        if (row == null) return false;

        // Verificar si el registro está anulado
        if (row.Table.Columns.Contains("Anulado"))
        {
            var anulado = row["Anulado"];
            if (anulado != null && anulado != DBNull.Value && Convert.ToBoolean(anulado))
            {
                return false; // Si el checkbox está seleccionado (anulado = true), no permitir modificar
            }
        }

        return true;
    }

    private bool CanConsult()
    {
        // Solo permitir consultar si hay exactamente UN registro seleccionado
        return state.SelectedRowIds.Count == 1;
    }

    private bool CanDeactivate()
    {
        if (state.SelectedRowIds.Count == 0) return false;

        // Verificar que TODOS los registros seleccionados NO estén anulados
        foreach (var row in GetSelectedRows())
        {
            if (row.Table.Columns.Contains("Anulado"))
            {
                var anulado = row["Anulado"];
                if (anulado != null && anulado != DBNull.Value && Convert.ToBoolean(anulado))
                {
                    return false; // Si encontramos algún registro anulado, no permitir desactivar
                }
            }
        }

        return true; // Todos los registros NO están anulados
    }

    private bool CanReactivate()
    {
        if (state.SelectedRowIds.Count == 0) return false;

        // Verificar que TODOS los registros seleccionados estén anulados
        foreach (var row in GetSelectedRows())
        {
            if (row.Table.Columns.Contains("Anulado"))
            {
                var anulado = row["Anulado"];
                if (anulado == null || anulado == DBNull.Value || !Convert.ToBoolean(anulado))
                {
                    return false; // Si encontramos algún registro NO anulado, no permitir reactivar
                }
            }
            else
            {
                return false; // Si no existe la columna Anulado, no permitir reactivar
            }
        }

        return true; // Todos los registros están anulados
    }

    private bool CanDelete()
    {
        if (state.SelectedRowIds.Count == 0) return false;

        // Verificar que TODOS los registros seleccionados estén anulados
        foreach (var row in GetSelectedRows())
        {
            if (row.Table.Columns.Contains("Anulado"))
            {
                var anulado = row["Anulado"];
                if (anulado == null || anulado == DBNull.Value || !Convert.ToBoolean(anulado))
                {
                    return false; // Si encontramos algún registro NO anulado, no permitir eliminar
                }
            }
            else
            {
                return false; // Si no existe la columna Anulado, no permitir eliminar
            }
        }

        return true; // Todos los registros están anulados
    }

