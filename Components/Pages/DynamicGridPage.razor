    private void OnImprimir()
    {
        if (state.GridData == null || state.GridData.Rows.Count == 0)
            return;

        try
        {
            // Crear una copia del DataTable con TODAS las columnas visibles
            var previewTable = new DataTable();

            // Agregar solo las columnas visibles en el orden configurado
            foreach (var column in GetOrderedColumns())
            {
                if (!ShouldHideColumn(column.ColumnName))
                {
                    previewTable.Columns.Add(column.ColumnName, column.DataType);
                }
            }

            // Copiar todas las filas filtradas/ordenadas (sin paginación)
            foreach (DataRow row in GetFilteredData())
            {
                var newRow = previewTable.NewRow();
                foreach (DataColumn column in previewTable.Columns)
                {
                    newRow[column.ColumnName] = row[column.ColumnName];
                }
                previewTable.Rows.Add(newRow);
            }

            // Guardar en el estado y mostrar el diálogo
            state.PrintPreviewData = previewTable;
            state.ShowPrintPreview = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            // Registrar error si es necesario
        }
    }

