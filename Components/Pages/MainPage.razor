@page "/"
@layout SimpleLayout
@using PredatorWeb.Services
@inject MenuService MenuService
@rendermode InteractiveServer

<PageTitle>PredatorWeb</PageTitle>

<div class="main-page-container">
    <div class="top-menu">
        <DxMenu Orientation="Orientation.Horizontal" 
                CssClass="horizontal-menu">
            <Items>
                @if (!isLoggedIn)
                {
                    <DxMenuItem>
                        <Template>
                            <span class="custom-menu-item">ERP Predator</span>
                        </Template>
                    </DxMenuItem>
                }
                else if (isLoading)
                {
                    <DxMenuItem>
                        <Template>
                            <span class="custom-menu-item">Cargando menú...</span>
                        </Template>
                    </DxMenuItem>
                }
                else if (menuItems.Count == 0)
                {
                    <DxMenuItem>
                        <Template>
                            <span class="custom-menu-item">Sin opciones de menú</span>
                        </Template>
                    </DxMenuItem>
                }
                else
                {
                    <DxMenuItem Text="@(selectedModuleName ?? "Modulos")">
                        <Items>
                            @foreach (var menuItem in menuItems)
                            {
                                <DxMenuItem Text="@menuItem.Menu" 
                                           Click="@(() => OnModuleSelected(menuItem))"></DxMenuItem>
                            }
                        </Items>
                    </DxMenuItem>

                    @if (subMenuItems.Count > 0)
                    {
                        @foreach (var subMenuItem in subMenuItems)
                        {
                            <DxMenuItem Click="@(() => OnSubMenuItemClick(subMenuItem))">
                                <Template>
                                    <span class="custom-menu-item">@subMenuItem.Menu</span>
                                </Template>
                            </DxMenuItem>
                        }
                    }
                }
            </Items>
        </DxMenu>
    </div>

    <div class="tab-container">
        <DxTabs CssClass="tabs" 
                @bind-ActiveTabIndex="@activeTabIndex">
            <!-- Pestaña Login siempre visible sin botón de cierre -->
            <DxTabPage Text="Login" 
                       CssClass="login-tab">
                <ChildContent>
                    <div class="login-content">
                        <DxFormLayout CssClass="login-form">
                            <DxFormLayoutGroup ColSpanMd="12">
                                <Items>
                                    <DxFormLayoutItem Caption="Código de Empresa:" 
                                                     ColSpanMd="12"
                                                     CaptionPosition="CaptionPosition.Vertical">
                                        <Template>
                                            <DxTextBox @bind-Text="@companyCode" 
                                                      CssClass="login-textbox"
                                                      NullText="Ingrese el código de empresa" />
                                        </Template>
                                    </DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Usuario:" 
                                                     ColSpanMd="12"
                                                     CaptionPosition="CaptionPosition.Vertical">
                                        <Template>
                                            <DxTextBox @bind-Text="@username" 
                                                      CssClass="login-textbox"
                                                      NullText="Ingrese su usuario" />
                                        </Template>
                                    </DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Contraseña:" 
                                                     ColSpanMd="12"
                                                     CaptionPosition="CaptionPosition.Vertical">
                                        <Template>
                                            <DxTextBox @bind-Text="@password" 
                                                      Password="true"
                                                      CssClass="login-textbox"
                                                      NullText="Ingrese su contraseña" />
                                        </Template>
                                    </DxFormLayoutItem>
                                    <DxFormLayoutItem ColSpanMd="12" 
                                                     CssClass="button-item">
                                        <Template>
                                            <div style="display: flex; justify-content: center; width: 100%;">
                                                <DxButton Text="Iniciar Sesión" 
                                                         RenderStyle="ButtonRenderStyle.Primary" 
                                                         Click="OnLoginClick"
                                                         CssClass="login-button" />
                                            </div>
                                        </Template>
                                    </DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Recordar Credenciales" ColSpanMd="12" 
                                                     CssClass="checkbox-item">
                                        <Template>
                                            <DxCheckBox @bind-Checked="@rememberCredentials" 
                                                       CssClass="remember-checkbox" />
                                        </Template>
                                    </DxFormLayoutItem>
                                </Items>
                            </DxFormLayoutGroup>
                        </DxFormLayout>
                    </div>
                </ChildContent>
            </DxTabPage>

            @foreach (var tab in openTabs)
            {
                <DxTabPage CssClass="dynamic-tab-page">
                    <TextTemplate>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <span>@tab.Title</span>
                            <span @onclick="@(() => CloseTab(tab))" 
                                  style="cursor: pointer; font-weight: bold; padding: 2px 6px; margin-left: 8px;"
                                  title="Cerrar">✕</span>
                        </div>
                    </TextTemplate>
                    <ChildContent>
                        @if (tab.ComponentType != null)
                        {
                            <DynamicComponent Type="@tab.ComponentType" 
                                            Parameters="@(tab.Parameters ?? new Dictionary<string, object>())" />
                        }
                        else
                        {
                            <div style="padding: 20px;">
                                <h3>@tab.Title</h3>
                                <p>Contenido de @tab.Title</p>
                                <p>NombreEntidad: @tab.NombreEntidad</p>
                            </div>
                        }
                    </ChildContent>
                </DxTabPage>
            }
        </DxTabs>
    </div>
</div>

@code {
    private string companyCode = "";
    private string username = "";
    private string password = "";
    private bool rememberCredentials = false;
    private List<Models.GrlMenu> menuItems = new();
    private List<Models.GrlMenu> subMenuItems = new();
    private List<Models.ListaPage> openTabs = new();
    private int activeTabIndex = 0;
    private bool isLoading = false;
    private bool isLoggedIn = false;
    private string? selectedModuleName = null;

    protected override Task OnInitializedAsync()
    {
        return Task.CompletedTask;
    }

    private async Task OnLoginClick()
    {
        try
        {
            isLoading = true;
            menuItems = await MenuService.GetMenuItemsAsync();
            isLoggedIn = true;

            // Cargar automáticamente el módulo "Ventas"
            var ventasModule = menuItems.FirstOrDefault(m => m.Menu.Equals("Ventas", StringComparison.OrdinalIgnoreCase));
            if (ventasModule != null)
            {
                await OnModuleSelected(ventasModule);
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error al cargar el menú: {ex.Message}");
            menuItems = new List<Models.GrlMenu>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnModuleSelected(Models.GrlMenu module)
    {
        try
        {
            selectedModuleName = module.Menu;
            subMenuItems = await MenuService.GetSubMenuItemsAsync(module.MenuId);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error al cargar submenús: {ex.Message}");
            subMenuItems = new List<Models.GrlMenu>();
        }
    }

    private void OnSubMenuItemClick(Models.GrlMenu subMenuItem)
    {
        var existingTab = openTabs.FirstOrDefault(t => t.NombreEntidad == subMenuItem.NombreEntidad);

        if (existingTab != null)
        {
            activeTabIndex = openTabs.IndexOf(existingTab) + 1;
        }
        else
        {
            var newTab = new Models.ListaPage
            {
                Title = subMenuItem.Menu,
                NombreEntidad = subMenuItem.NombreEntidad,
                MenuId = subMenuItem.MenuId,
                ComponentType = typeof(GridPage),
                Parameters = new Dictionary<string, object>
                {
                    { "NombreEntidad", subMenuItem.NombreEntidad }
                }
            };

            openTabs.Add(newTab);
            activeTabIndex = openTabs.Count;
        }
    }

    private void CloseTab(Models.ListaPage tab)
    {
        var index = openTabs.IndexOf(tab);
        openTabs.Remove(tab);

        if (activeTabIndex == index + 1)
        {
            activeTabIndex = 0;
        }
        else if (activeTabIndex > index + 1)
        {
            activeTabIndex--;
        }
    }
}
