@page "/"
@layout SimpleLayout
@using PredatorWeb.Services
@inject MenuService MenuService
@inject EntidadService EntidadService
@inject Datos DatosService
@inject SessionService SessionService
@inject ILogger<MainPage> Logger
@rendermode InteractiveServer

<PageTitle>PredatorWeb</PageTitle>

<div class="main-page-container">
    <nav class="top-menu">
        <ul class="menu-horizontal">
            @if (!isLoggedIn)
            {
                <li class="menu-item">ERP Predator</li>
            }
            else if (isLoading)
            {
                <li class="menu-item">Cargando menú...</li>
            }
            else if (menuItems.Count == 0)
            {
                <li class="menu-item">Sin opciones de menú</li>
            }
            else
            {
                <li class="menu-item dropdown">
                    <button class="menu-button" @onclick="ToggleModulesDropdown">
                        @(selectedModuleName ?? "Modulos") ▼
                    </button>
                    @if (showModulesDropdown)
                    {
                        <ul class="dropdown-menu">
                            @foreach (var menuItem in menuItems)
                            {
                                <li>
                                    <button class="dropdown-item" @onclick="@(async () => await OnModuleSelected(menuItem))">
                                        @menuItem.Menu
                                    </button>
                                </li>
                            }
                        </ul>
                    }
                </li>

                @foreach (var subMenuItem in subMenuItems)
                {
                    <li class="menu-item">
                        <button class="menu-button" @onclick="@(() => OnSubMenuItemClick(subMenuItem))">
                            @subMenuItem.Menu
                        </button>
                    </li>
                }
            }
        </ul>
    </nav>

    <div class="tab-container">
        <div class="tabs">
            <div class="tab-headers">
                <button class="tab-header @(activeTabIndex == 0 ? "active" : "")" 
                        @onclick="@(() => activeTabIndex = 0)">
                    Login
                </button>

                @for (int i = 0; i < openTabs.Count; i++)
                {
                    var index = i;
                    var tab = openTabs[i];
                    <button class="tab-header @(activeTabIndex == index + 1 ? "active" : "")" 
                            @onclick="@(() => activeTabIndex = index + 1)">
                        @tab.Title
                        <span class="tab-close" @onclick="@(e => OnTabClose(e, tab))" @onclick:stopPropagation="true">✕</span>
                    </button>
                }
            </div>

            <div class="tab-content">
                <!-- Pestaña de inicio de sesión (siempre presente) -->
                <div style="display: @(activeTabIndex == 0 ? "block" : "none")">
                    <div class="login-content">
                        <div class="login-form">
                            @if (!string.IsNullOrEmpty(loginErrorMessage))
                            {
                                <div class="form-group">
                                    <div style="background-color: #ffebee; color: #c62828; padding: 12px; border-radius: 4px; border: 1px solid #ef5350; margin-bottom: 15px; max-height: 400px; overflow-y: auto; white-space: pre-wrap; font-size: 11px; line-height: 1.4;">
                                        <strong>⚠️</strong> @loginErrorMessage
                                    </div>
                                </div>
                            }
                            <div class="form-group">
                                <label>Código de Empresa:</label>
                                <input type="text" class="form-control" @bind="companyCode" placeholder="Ingrese el código de empresa" />
                            </div>
                            <div class="form-group">
                                <label>Usuario:</label>
                                <input type="text" class="form-control" @bind="username" placeholder="Ingrese su usuario" />
                            </div>
                            <div class="form-group">
                                <label>Contraseña:</label>
                                <input type="password" class="form-control" @bind="password" placeholder="Ingrese su contraseña" />
                            </div>
                            <div class="form-group">
                                <button class="btn-primary" @onclick="OnLoginClick">Iniciar Sesión</button>
                            </div>
                            <div class="form-group">
                                <label>
                                    <input type="checkbox" @bind="rememberCredentials" />
                                    Recordar Credenciales
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Pestañas de entidades (renderizadas todas, pero ocultas con CSS) -->
                @for (int i = 0; i < openTabs.Count; i++)
                {
                    var tabIndex = i;
                    var tab = openTabs[tabIndex];
                    var isActive = activeTabIndex == tabIndex + 1;

                    <div style="display: @(isActive ? "flex" : "none"); flex-direction: column; height: 100%; overflow: hidden;">
                        @if (tab.ComponentType != null)
                        {
                            <DynamicComponent Type="@tab.ComponentType" 
                                            Parameters="@(tab.Parameters ?? new Dictionary<string, object>())"
                                            @key="@tab.NombreEntidad" />
                        }
                        else
                        {
                            <div style="padding: 20px;">
                                <h3>@tab.Title</h3>
                                <p>Contenido de @tab.Title</p>
                                <p>NombreEntidad: @tab.NombreEntidad</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string companyCode = "";
    private string username = "";
    private string password = "";
    private bool rememberCredentials = false;
    private string loginErrorMessage = "";
    private List<Models.GrlMenu> menuItems = new();
    private List<Models.GrlMenu> subMenuItems = new();
    private List<Models.ListaPage> openTabs = new();
    private int activeTabIndex = 0;
    private bool isLoading = false;
    private bool isLoggedIn = false;
    private string? selectedModuleName = null;
    private bool showModulesDropdown = false;

    protected override Task OnInitializedAsync()
    {
        return Task.CompletedTask;
    }

    private void ToggleModulesDropdown()
    {
        showModulesDropdown = !showModulesDropdown;
    }

    private async Task OnLoginClick()
    {
        try
        {
            loginErrorMessage = "";
            isLoading = true;
            StateHasChanged();

            // Validar que se hayan ingresado todos los campos
            if (string.IsNullOrWhiteSpace(companyCode))
            {
                loginErrorMessage = "Por favor, ingrese el código de empresa.";
                return;
            }

            if (string.IsNullOrWhiteSpace(username))
            {
                loginErrorMessage = "Por favor, ingrese el nombre de usuario.";
                return;
            }

            if (string.IsNullOrWhiteSpace(password))
            {
                loginErrorMessage = "Por favor, ingrese la contraseña.";
                return;
            }

            // Configurar la conexión basada en el código de empresa
            bool connectionConfigured = await DatosService.ConfigureConnectionByCompanyAsync(companyCode);

            if (!connectionConfigured)
            {
                loginErrorMessage = "La empresa no existe. Por favor, verifique el código ingresado.";
                return;
            }

            // Validar las credenciales del usuario
            var userValidationResult = await DatosService.ValidateUserCredentialsAsync(companyCode, username, password);

            if (userValidationResult.Rows.Count == 0)
            {
                loginErrorMessage = "El usuario no existe. Por favor, verifique el nombre de usuario ingresado.";
                DatosService.ResetConnection();
                return;
            }

            var validationRow = userValidationResult.Rows[0];

            // Verificar si existe la columna ClaveCorrecta
            if (!userValidationResult.Columns.Contains("ClaveCorrecta"))
            {
                loginErrorMessage = "Error en el procedimiento de validación: no se encontró la columna 'ClaveCorrecta'.";
                DatosService.ResetConnection();
                return;
            }

            bool claveCorrecta = false;
            var claveCorrectaValue = validationRow["ClaveCorrecta"];

            if (claveCorrectaValue != null && claveCorrectaValue != DBNull.Value)
            {
                claveCorrecta = Convert.ToBoolean(claveCorrectaValue);
            }

            if (!claveCorrecta)
            {
                loginErrorMessage = "Contraseña incorrecta. Por favor, verifique sus credenciales.";
                DatosService.ResetConnection();
                return;
            }

            // Verificar si la cuenta del usuario está activa
            if (userValidationResult.Columns.Contains("Inactivo"))
            {
                var inactivoValue = validationRow["Inactivo"];
                if (inactivoValue != null && inactivoValue != DBNull.Value)
                {
                    bool usuarioInactivo = Convert.ToBoolean(inactivoValue);
                    if (usuarioInactivo)
                    {
                        loginErrorMessage = "La cuenta de usuario ha caducado. Por favor, contacte al administrador.";
                        DatosService.ResetConnection();
                        return;
                    }
                }
            }

            // Verificar si el usuario tiene acceso a alguna sede
            if (userValidationResult.Columns.Contains("SedeId"))
            {
                var sedeIdValue = validationRow["SedeId"];
                if (sedeIdValue == null || sedeIdValue == DBNull.Value)
                {
                    loginErrorMessage = "El usuario no tiene acceso a ninguna sede. Por favor, contacte al administrador.";
                    DatosService.ResetConnection();
                    return;
                }
            }

            // Si llegamos aquí, las credenciales son correctas y el usuario tiene acceso

            // Guardar EmpresaId y UsuarioId en la sesión
            if (userValidationResult.Columns.Contains("EmpresaId"))
            {
                var empresaIdValue = validationRow["EmpresaId"];
                if (empresaIdValue != null && empresaIdValue != DBNull.Value)
                {
                    SessionService.EmpresaId = Convert.ToInt32(empresaIdValue);
                }
            }

            if (userValidationResult.Columns.Contains("UsuarioId"))
            {
                var usuarioIdValue = validationRow["UsuarioId"];
                if (usuarioIdValue != null && usuarioIdValue != DBNull.Value)
                {
                    SessionService.UsuarioId = Convert.ToInt32(usuarioIdValue);
                }
            }

            // Cargar el menú
            menuItems = await MenuService.GetMenuItemsAsync();

            isLoggedIn = true;
            StateHasChanged();

            // Seleccionar automáticamente el módulo de Ventas si existe
            var ventasModule = menuItems.FirstOrDefault(m => m.Menu.Equals("Ventas", StringComparison.OrdinalIgnoreCase));
            if (ventasModule != null)
            {
                await OnModuleSelected(ventasModule);
            }
        }
        catch (Exception ex)
        {
            var innerError = ex.InnerException != null ? $"\nError Interno: {ex.InnerException.Message}" : "";
            loginErrorMessage = $"Error al iniciar sesión:\n{ex.Message}{innerError}\n\nStack: {ex.StackTrace}";
            menuItems = new List<Models.GrlMenu>();
            DatosService.ResetConnection();
            StateHasChanged();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnModuleSelected(Models.GrlMenu module)
    {
        try
        {
            selectedModuleName = module.Menu;
            subMenuItems = await MenuService.GetSubMenuItemsAsync(module.MenuId);
            showModulesDropdown = false;
        }
        catch (Exception ex)
        {
            subMenuItems = new List<Models.GrlMenu>();
        }
    }

    private void OnSubMenuItemClick(Models.GrlMenu subMenuItem)
    {
        var entidad = !string.IsNullOrEmpty(subMenuItem.NombreEntidad) 
            ? EntidadService.GetEntidad(subMenuItem.NombreEntidad) 
            : null;

        var nombreEntidad = entidad?.NombreEntidad ?? subMenuItem.NombreEntidad;
        var titulo = entidad?.NombrePlural ?? subMenuItem.Menu;

        var existingTab = openTabs.FirstOrDefault(t => t.NombreEntidad == nombreEntidad);

        if (existingTab != null)
        {
            activeTabIndex = openTabs.IndexOf(existingTab) + 1;
        }
        else
        {
            var newTab = new Models.ListaPage
            {
                Title = titulo,
                NombreEntidad = nombreEntidad,
                MenuId = subMenuItem.MenuId,
                ComponentType = typeof(DynamicGridPage),
                Parameters = new Dictionary<string, object>
                {
                    { "NombreEntidad", nombreEntidad }
                }
            };

            openTabs.Add(newTab);
            activeTabIndex = openTabs.Count;
        }
    }

    private void OnTabClose(MouseEventArgs e, Models.ListaPage tab)
    {
        CloseTab(tab);
    }

    private void CloseTab(Models.ListaPage tab)
    {
        var index = openTabs.IndexOf(tab);
        openTabs.Remove(tab);

        if (activeTabIndex == index + 1)
        {
            activeTabIndex = 0;
        }
        else if (activeTabIndex > index + 1)
        {
            activeTabIndex--;
        }
    }
}
