@page "/"
@layout SimpleLayout
@using PredatorWeb.Services
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using PredatorWeb.Components.Pages
@inject MenuService MenuService
@inject EntidadService EntidadService
@inject Datos DatosService
@inject SessionService SessionService
@inject ProtectedLocalStorage ProtectedLocalStorage
@inject ProtectedSessionStorage ProtectedSessionStorage
@inject ILogger<MainPage> Logger
@rendermode InteractiveServer

<PageTitle>PredatorWeb</PageTitle>

<div class="main-page-container">
    <nav class="top-menu">
        <ul class="menu-horizontal">
            @if (!isLoggedIn)
            {
                <li class="menu-item">ERP Predator</li>
            }
            else if (isLoading)
            {
                <li class="menu-item">Cargando menú...</li>
            }
            else if (menuItems.Count == 0)
            {
                <li class="menu-item">Sin opciones de menú</li>
            }
            else
            {
                <li class="menu-item dropdown">
                    <button class="menu-button" @onclick="ToggleModulesDropdown">
                        @(selectedModuleName ?? "Modulos") ▼
                    </button>
                    @if (showModulesDropdown)
                    {
                        <ul class="dropdown-menu">
                            @foreach (var menuItem in menuItems)
                            {
                                <li>
                                    <button class="dropdown-item" @onclick="@(async () => await OnModuleSelected(menuItem))">
                                        @menuItem.Menu
                                    </button>
                                </li>
                            }
                        </ul>
                    }
                </li>

                @foreach (var subMenuItem in subMenuItems)
                {
                    <li class="menu-item">
                        <button class="menu-button" @onclick="@(() => OnSubMenuItemClick(subMenuItem))">
                            @subMenuItem.Menu
                        </button>
                    </li>
                }
            }
        </ul>
    </nav>

    <div class="tab-container">
        <div class="tabs">
            <div class="tab-headers">
                <button class="tab-header @(activeTabIndex == 0 ? "active" : "")" 
                        @onclick="@(() => activeTabIndex = 0)">
                    Login
                </button>

                @for (int i = 0; i < openTabs.Count; i++)
                {
                    var index = i;
                    var tab = openTabs[i];
                    <button class="tab-header @(activeTabIndex == index + 1 ? "active" : "")" 
                            @onclick="@(() => activeTabIndex = index + 1)">
                        @tab.Title
                        <span class="tab-close" @onclick="@(e => OnTabClose(e, tab))" @onclick:stopPropagation="true">✕</span>
                    </button>
                }
            </div>

            <div class="tab-content">
                <!-- Pestaña de inicio de sesión (siempre presente) -->
                <div style="display: @(activeTabIndex == 0 ? "block" : "none")">
                    <div class="login-content">
                        <div class="login-form">
                            @if (!string.IsNullOrEmpty(loginErrorMessage))
                            {
                                <div class="form-group">
                                    <div style="background-color: #ffebee; color: #c62828; padding: 12px; border-radius: 4px; border: 1px solid #ef5350; margin-bottom: 15px; max-height: 400px; overflow-y: auto; white-space: pre-wrap; font-size: 11px; line-height: 1.4;">
                                        <strong>⚠️</strong> @loginErrorMessage
                                    </div>
                                </div>
                            }
                            <div class="form-group">
                                <label>Código de Empresa:</label>
                                <input type="text" class="form-control" @bind="companyCode" placeholder="Ingrese el código de empresa" autocomplete="off" disabled="@isLoggedIn" />
                                @if (isLoggedIn && !string.IsNullOrEmpty(companyDisplayName))
                                {
                                    <div class="company-display">@companyDisplayName</div>
                                }
                            </div>
                            @if (isLoggedIn && sedes != null && sedes.Rows.Count > 0)
                            {
                                <div class="form-group">
                                    <label>Sede:</label>
                                    <select class="form-control" value="@selectedSedeId" @onchange="OnSedeChanged">
                                        @foreach (System.Data.DataRow sede in sedes.Rows)
                                        {
                                            <option value="@sede["SedeId"]">@sede["Sede"]</option>
                                        }
                                    </select>
                                </div>
                            }
                            <div class="form-group">
                                <label>Usuario:</label>
                                <input type="text" class="form-control" @bind="username" placeholder="Ingrese su usuario" autocomplete="off" />
                            </div>
                            @if (!isLoggedIn)
                            {
                                <div class="form-group">
                                    <label>Contraseña:</label>
                                    <input type="password" class="form-control" @bind="password" placeholder="Ingrese su contraseña" autocomplete="new-password" />
                                </div>
                            }
                            <div class="form-group">
                                @if (!isLoggedIn)
                                {
                                    <button class="btn-primary" @onclick="OnLoginClick" disabled="@(!_pageReady)">Iniciar Sesión</button>
                                }
                                else
                                {
                                    <button class="btn-logout" @onclick="OnLogoutClick">Logout</button>
                                }
                            </div>
                            @if (!isLoggedIn)
                            {
                                <div class="form-group">
                                    <label>
                                        <input type="checkbox" @bind="rememberCredentials" />
                                        Recordar Credenciales
                                    </label>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Pestañas de entidades (renderizadas todas, pero ocultas con CSS) -->
                @for (int i = 0; i < openTabs.Count; i++)
                {
                    var tabIndex = i;
                    var tab = openTabs[tabIndex];
                    var isActive = activeTabIndex == tabIndex + 1;

                    <div style="display: @(isActive ? "flex" : "none"); flex-direction: column; height: 100%; overflow: hidden;">
                        @if (tab.ComponentType != null)
                        {
                            <DynamicComponent Type="@tab.ComponentType" 
                                            Parameters="@(tab.Parameters ?? new Dictionary<string, object>())"
                                            @key="@tab.NombreEntidad" />
                        }
                        else
                        {
                            <div style="padding: 20px;">
                                <h3>@tab.Title</h3>
                                <p>Contenido de @tab.Title</p>
                                <p>NombreEntidad: @tab.NombreEntidad</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string companyCode = "";
    private string username = "";
    private string password = "";
    private bool rememberCredentials = false;
    private string loginErrorMessage = "";
    private List<Models.GrlMenu> menuItems = new();
    private List<Models.GrlMenu> subMenuItems = new();
    private List<Models.ListaPage> openTabs = new();
    private int activeTabIndex = 0;
    private bool isLoading = false;
    private bool isLoggedIn = false;
    private string? selectedModuleName = null;
    private bool showModulesDropdown = false;
    private string companyDisplayName = "";
    private System.Data.DataTable? sedes = null;
    private int? selectedSedeId = null;

    private const string CredentialsStorageKey = "predator_credentials";
    private const string SedeStorageKey = "predator_sede_id";
    private bool _pageReady = false;

    protected override Task OnInitializedAsync()
    {
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadSavedCredentialsAsync();
            _pageReady = true;
            StateHasChanged();
        }
    }

    private async Task LoadSavedCredentialsAsync()
    {
        try
        {
            var result = await ProtectedLocalStorage.GetAsync<SavedCredentials>(CredentialsStorageKey);
            if (result.Success && result.Value is not null)
            {
                companyCode = result.Value.CompanyCode;
                username = result.Value.Username;
                password = result.Value.Password;
                rememberCredentials = true;
                StateHasChanged();
            }
        }
        catch
        {
            // Si falla la lectura (datos corruptos o clave cambiada), se ignora
        }
    }

    private async Task SaveOrClearCredentialsAsync()
    {
        try
        {
            if (rememberCredentials)
            {
                var credentials = new SavedCredentials
                {
                    CompanyCode = companyCode,
                    Username = username,
                    Password = password
                };
                await ProtectedLocalStorage.SetAsync(CredentialsStorageKey, credentials);
            }
            else
            {
                await ProtectedLocalStorage.DeleteAsync(CredentialsStorageKey);
            }
        }
        catch
        {
            // Se ignoran errores de almacenamiento para no interrumpir el login
        }
    }

    private sealed class SavedCredentials
    {
        public string CompanyCode { get; set; } = "";
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }

    private void ToggleModulesDropdown()
    {
        showModulesDropdown = !showModulesDropdown;
    }

    private async Task OnLoginClick()
    {
        try
        {
            loginErrorMessage = "";
            isLoading = true;
            StateHasChanged();

            // Validar que se hayan ingresado todos los campos
            if (string.IsNullOrWhiteSpace(companyCode))
            {
                loginErrorMessage = "Por favor, ingrese el código de empresa.";
                return;
            }

            if (string.IsNullOrWhiteSpace(username))
            {
                loginErrorMessage = "Por favor, ingrese el nombre de usuario.";
                return;
            }

            if (string.IsNullOrWhiteSpace(password))
            {
                loginErrorMessage = "Por favor, ingrese la contraseña.";
                return;
            }

            // Configurar la conexión basada en el código de empresa
            bool connectionConfigured = await DatosService.ConfigureConnectionByCompanyAsync(companyCode);

            if (!connectionConfigured)
            {
                loginErrorMessage = "La empresa no existe. Por favor, verifique el código ingresado.";
                return;
            }

            // Validar las credenciales del usuario
            var userValidationResult = await DatosService.ValidateUserCredentialsAsync(companyCode, username, password);

            if (userValidationResult.Rows.Count == 0)
            {
                loginErrorMessage = "El usuario no existe. Por favor, verifique el nombre de usuario ingresado.";
                DatosService.ResetConnection();
                return;
            }

            var validationRow = userValidationResult.Rows[0];

            // Verificar si existe la columna ClaveCorrecta
            if (!userValidationResult.Columns.Contains("ClaveCorrecta"))
            {
                loginErrorMessage = "Error en el procedimiento de validación: no se encontró la columna 'ClaveCorrecta'.";
                DatosService.ResetConnection();
                return;
            }

            bool claveCorrecta = false;
            var claveCorrectaValue = validationRow["ClaveCorrecta"];

            if (claveCorrectaValue != null && claveCorrectaValue != DBNull.Value)
            {
                claveCorrecta = Convert.ToBoolean(claveCorrectaValue);
            }

            if (!claveCorrecta)
            {
                loginErrorMessage = "Contraseña incorrecta. Por favor, verifique sus credenciales.";
                DatosService.ResetConnection();
                return;
            }

            // Verificar si la cuenta del usuario está activa
            if (userValidationResult.Columns.Contains("Inactivo"))
            {
                var inactivoValue = validationRow["Inactivo"];
                if (inactivoValue != null && inactivoValue != DBNull.Value)
                {
                    bool usuarioInactivo = Convert.ToBoolean(inactivoValue);
                    if (usuarioInactivo)
                    {
                        loginErrorMessage = "La cuenta de usuario ha caducado. Por favor, contacte al administrador.";
                        DatosService.ResetConnection();
                        return;
                    }
                }
            }

            // Verificar si el usuario tiene acceso a alguna sede
            if (userValidationResult.Columns.Contains("SedeId"))
            {
                var sedeIdValue = validationRow["SedeId"];
                if (sedeIdValue == null || sedeIdValue == DBNull.Value)
                {
                    loginErrorMessage = "El usuario no tiene acceso a ninguna sede. Por favor, contacte al administrador.";
                    DatosService.ResetConnection();
                    return;
                }
            }

            // Si llegamos aquí, las credenciales son correctas y el usuario tiene acceso

            // Guardar o limpiar las credenciales según el checkbox "Recordar Credenciales"
            await SaveOrClearCredentialsAsync();

            // Guardar EmpresaId y UsuarioId en la sesión
            if (userValidationResult.Columns.Contains("EmpresaId"))
            {
                var empresaIdValue = validationRow["EmpresaId"];
                if (empresaIdValue != null && empresaIdValue != DBNull.Value)
                {
                    SessionService.EmpresaId = Convert.ToInt32(empresaIdValue);
                }
            }

            if (userValidationResult.Columns.Contains("UsuarioId"))
            {
                var usuarioIdValue = validationRow["UsuarioId"];
                if (usuarioIdValue != null && usuarioIdValue != DBNull.Value)
                {
                    SessionService.UsuarioId = Convert.ToInt32(usuarioIdValue);
                }
            }

            // Cargar el menú
            menuItems = await MenuService.GetMenuItemsAsync();

            // Determinar el nombre a mostrar de la empresa
            companyDisplayName = GetCompanyDisplayName(userValidationResult, validationRow);

            // Cargar las sedes autorizadas para el usuario
            if (SessionService.EmpresaId.HasValue && SessionService.UsuarioId.HasValue)
            {
                sedes = await DatosService.GetSedesByUsuarioAsync(SessionService.EmpresaId.Value, SessionService.UsuarioId.Value);
                if (sedes != null && sedes.Rows.Count > 0)
                {
                    // Intentar restaurar la sede persistida de la sesión
                    int? sedePersistida = null;
                    try
                    {
                        var sedeResult = await ProtectedSessionStorage.GetAsync<int>(SedeStorageKey);
                        if (sedeResult.Success)
                        {
                            sedePersistida = sedeResult.Value;
                        }
                    }
                    catch { }

                    // Usar la sede persistida si sigue siendo válida; si no, la primera
                    bool sedeValida = false;
                    if (sedePersistida.HasValue)
                    {
                        foreach (System.Data.DataRow r in sedes.Rows)
                        {
                            if (r["SedeId"] != DBNull.Value && Convert.ToInt32(r["SedeId"]) == sedePersistida.Value)
                            {
                                sedeValida = true;
                                break;
                            }
                        }
                    }

                    if (sedeValida)
                    {
                        selectedSedeId = sedePersistida;
                    }
                    else
                    {
                        var primeraSede = sedes.Rows[0]["SedeId"];
                        if (primeraSede != null && primeraSede != DBNull.Value)
                        {
                            selectedSedeId = Convert.ToInt32(primeraSede);
                        }
                    }

                    SessionService.SedeId = selectedSedeId;
                    if (selectedSedeId.HasValue)
                    {
                        await ProtectedSessionStorage.SetAsync(SedeStorageKey, selectedSedeId.Value);
                    }
                }
            }

            isLoggedIn = true;
            StateHasChanged();

            // Seleccionar automáticamente el módulo de Ventas si existe
            var ventasModule = menuItems.FirstOrDefault(m => m.Menu.Equals("Ventas", StringComparison.OrdinalIgnoreCase));
            if (ventasModule != null)
            {
                await OnModuleSelected(ventasModule);
            }
        }
        catch (Exception ex)
        {
            var innerError = ex.InnerException != null ? $"\nError Interno: {ex.InnerException.Message}" : "";
            loginErrorMessage = $"Error al iniciar sesión:\n{ex.Message}{innerError}\n\nStack: {ex.StackTrace}";
            menuItems = new List<Models.GrlMenu>();
            DatosService.ResetConnection();
            StateHasChanged();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnLogoutClick()
    {
        // Ocultar la empresa y restaurar el estado del formulario
        isLoggedIn = false;
        companyDisplayName = "";
        sedes = null;
        selectedSedeId = null;

        // Limpiar menús y pestañas abiertas
        menuItems = new List<Models.GrlMenu>();
        subMenuItems = new List<Models.GrlMenu>();
        openTabs = new List<Models.ListaPage>();
        activeTabIndex = 0;
        selectedModuleName = null;
        showModulesDropdown = false;
        loginErrorMessage = "";

        // Borrar los datos persistentes de la sesión
        SessionService.EmpresaId = null;
        SessionService.UsuarioId = null;
        SessionService.SedeId = null;
        SessionService.IsLoggedIn = false;
        SessionService.CompanyCode = null;
        SessionService.Username = null;

        // Restablecer la conexión de datos
        DatosService.ResetConnection();

        // Borrar la sede persistida en la sesión
        await ProtectedSessionStorage.DeleteAsync(SedeStorageKey);

        StateHasChanged();
    }

    private async Task OnSedeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var sedeId))
        {
            selectedSedeId = sedeId;
            SessionService.SedeId = sedeId;
            await ProtectedSessionStorage.SetAsync(SedeStorageKey, sedeId);
        }
    }

    private string GetCompanyDisplayName(System.Data.DataTable validationResult, System.Data.DataRow validationRow)
    {
        // El nombre de la empresa proviene de la columna "Empresa" del resultado de GrlUsuariosMantenimiento
        if (validationResult.Columns.Contains("Empresa"))
        {
            var valor = validationRow["Empresa"];
            if (valor != null && valor != DBNull.Value)
            {
                var texto = valor.ToString();
                if (!string.IsNullOrWhiteSpace(texto))
                {
                    return texto;
                }
            }
        }

        // Respaldo: mostrar el código de empresa ingresado
        return companyCode;
    }

    private async Task OnModuleSelected(Models.GrlMenu module)
    {
        try
        {
            selectedModuleName = module.Menu;
            subMenuItems = await MenuService.GetSubMenuItemsAsync(module.MenuId);
            showModulesDropdown = false;
        }
        catch (Exception ex)
        {
            subMenuItems = new List<Models.GrlMenu>();
        }
    }

    private void OnSubMenuItemClick(Models.GrlMenu subMenuItem)
    {
        var entidad = !string.IsNullOrEmpty(subMenuItem.NombreEntidad) 
            ? EntidadService.GetEntidad(subMenuItem.NombreEntidad) 
            : null;

        var nombreEntidad = entidad?.NombreEntidad ?? subMenuItem.NombreEntidad;
        var titulo = entidad?.NombrePlural ?? subMenuItem.Menu;

        var existingTab = openTabs.FirstOrDefault(t => t.NombreEntidad == nombreEntidad);

        if (existingTab != null)
        {
            activeTabIndex = openTabs.IndexOf(existingTab) + 1;
        }
        else
        {
            var newTab = new Models.ListaPage
            {
                Title = titulo,
                NombreEntidad = nombreEntidad,
                MenuId = subMenuItem.MenuId,
                ComponentType = typeof(DynamicGridPage),
                Parameters = new Dictionary<string, object>
                {
                    { "NombreEntidad", nombreEntidad },
                    { "OpenPrintPreviewTab", EventCallback.Factory.Create<(string, System.Data.DataTable)>(this, OpenPrintPreviewTabHandler) }
                }
            };

            openTabs.Add(newTab);
            activeTabIndex = openTabs.Count;
        }
    }

    private void OnTabClose(MouseEventArgs e, Models.ListaPage tab)
    {
        CloseTab(tab);
    }

    private int _printPreviewVersion = 0;
    private const string PrintTabKey = "__print__";

    private void OpenPrintPreviewTabHandler((string Title, System.Data.DataTable Data) args)
    {
        _printPreviewVersion++;

        var existing = openTabs.FirstOrDefault(t => t.NombreEntidad.StartsWith(PrintTabKey));
        if (existing != null)
        {
            // Reemplazar la pestaña existente con datos nuevos forzando re-render con nueva key
            var tabIndex = openTabs.IndexOf(existing);
            Models.ListaPage? newTab = null;
            newTab = new Models.ListaPage
            {
                Title = "🖨️ Impresión",
                NombreEntidad = $"{PrintTabKey}{_printPreviewVersion}",
                ComponentType = typeof(PrintPreviewPage),
                Parameters = new Dictionary<string, object>
                {
                    { "Title", args.Title },
                    { "PreviewData", args.Data },
                    { "OnClose", EventCallback.Factory.Create(this, () => CloseTab(newTab!)) }
                }
            };
            openTabs[tabIndex] = newTab;
            activeTabIndex = tabIndex + 1;
        }
        else
        {
            Models.ListaPage? newTab = null;
            newTab = new Models.ListaPage
            {
                Title = "🖨️ Impresión",
                NombreEntidad = $"{PrintTabKey}{_printPreviewVersion}",
                ComponentType = typeof(PrintPreviewPage),
                Parameters = new Dictionary<string, object>
                {
                    { "Title", args.Title },
                    { "PreviewData", args.Data },
                    { "OnClose", EventCallback.Factory.Create(this, () => CloseTab(newTab!)) }
                }
            };
            openTabs.Add(newTab);
            activeTabIndex = openTabs.Count;
        }

        StateHasChanged();
    }

    private void CloseTab(Models.ListaPage tab)
    {
        var index = openTabs.IndexOf(tab);
        openTabs.Remove(tab);

        if (activeTabIndex == index + 1)
        {
            activeTabIndex = 0;
        }
        else if (activeTabIndex > index + 1)
        {
            activeTabIndex--;
        }
    }
}
